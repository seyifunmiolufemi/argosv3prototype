<!-- ALERTS DUPLICATE MODAL -->
<div id="alerts-duplicate-modal" class="pm-modal-overlay" style="display:none;">
  <div class="pm-modal-box" style="width:440px;">
    <div class="pm-modal-header">
      <span style="font-size:16px;font-weight:600;color:var(--color-text-primary);">Duplicate Alert</span>
    </div>
    <div class="pm-modal-body">
      <p style="font-size:13px;color:var(--color-text-subtitle);margin-bottom:16px;">Choose what to duplicate from the original alert.</p>
      <div style="margin-bottom:16px;">
        <label class="field-label">Alert Name <span style="color:#d72225;">*</span></label>
        <input type="text" class="modal-input" id="dup-name-input" style="width:100%;box-sizing:border-box;">
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        <label style="display:flex;align-items:center;gap:8px;font-size:14px;cursor:pointer;"><input type="checkbox" id="dup-cb-ds" checked> Data Source</label>
        <label style="display:flex;align-items:center;gap:8px;font-size:14px;cursor:pointer;"><input type="checkbox" id="dup-cb-metrics" checked> Metrics</label>
        <label style="display:flex;align-items:center;gap:8px;font-size:14px;cursor:pointer;"><input type="checkbox" id="dup-cb-conditions" checked> Conditions</label>
        <label style="display:flex;align-items:center;gap:8px;font-size:14px;cursor:pointer;"><input type="checkbox" id="dup-cb-schedule" checked> Schedule</label>
        <label style="display:flex;align-items:center;gap:8px;font-size:14px;cursor:pointer;"><input type="checkbox" id="dup-cb-notifs" checked> Notifications Setup</label>
      </div>
    </div>
    <div class="pm-modal-footer" style="display:flex;gap:10px;justify-content:flex-end;">
      <button class="btn-outline" onclick="document.getElementById('alerts-duplicate-modal').style.display='none'">Cancel</button>
      <button class="btn-primary-sm" onclick="alertsDuplicateConfirm()">Duplicate Alert</button>
    </div>
  </div>
</div>

<!-- ALERTS PREVIEW MODAL -->
<div id="alerts-preview-modal" class="pm-modal-overlay" style="display:none;">
  <div class="pm-modal-box" style="width:480px;">
    <div class="pm-modal-header">
      <span style="font-size:16px;font-weight:600;color:var(--color-text-primary);">Alert Message Preview</span>
    </div>
    <div class="pm-modal-body">
      <p style="font-size:13px;color:var(--color-text-subtitle);margin-bottom:16px;">This is a preview. Actual values may vary when the alert triggers.</p>
      <div class="slack-preview-card">
        <div class="slack-preview-title">🚨 Alert Triggered: <span id="alerts-preview-name">Budget Alert</span></div>
        <div class="slack-preview-row"><span class="slack-preview-label">Platform:</span><span id="alerts-preview-platform">Google Ads</span></div>
        <div class="slack-preview-row"><span class="slack-preview-label">Triggered:</span><span>Dec 4, 2025 · 2:00 AM</span></div>
        <div class="slack-preview-row"><span class="slack-preview-label">Condition:</span><span>COS is greater than 50 over 7 days</span></div>
        <div class="slack-preview-row"><span class="slack-preview-label">Value:</span><span style="color:#f87171;">54.2%</span></div>
        <div style="margin-top:12px;padding-top:10px;border-top:1px solid #2e3035;font-size:12px;color:#6b6f73;">View in Argos →</div>
      </div>
    </div>
    <div class="pm-modal-footer" style="display:flex;justify-content:flex-end;">
      <button class="btn-outline" onclick="document.getElementById('alerts-preview-modal').style.display='none'">Close</button>
    </div>
  </div>
</div>

<!-- ALERTS CONDITION MODAL -->
<div id="alerts-condition-modal" class="pm-modal-overlay" style="display:none;">
  <div class="pm-modal-box" style="width:460px;">
    <div class="pm-modal-header">
      <span style="font-size:16px;font-weight:600;color:var(--color-text-primary);">Triggered Condition</span>
    </div>
    <div class="pm-modal-body">
      <p style="font-size:13px;color:var(--color-text-subtitle);margin-bottom:12px;">Condition that triggered this alert for <strong id="condition-modal-client"></strong></p>
      <p style="font-size:12px;color:var(--color-text-caption);margin-bottom:12px;">Triggered at: <span id="condition-modal-time"></span></p>
      <div class="condition-display" id="condition-modal-text"></div>
    </div>
    <div class="pm-modal-footer" style="display:flex;justify-content:flex-end;">
      <button class="btn-outline" onclick="document.getElementById('alerts-condition-modal').style.display='none'">Close</button>
    </div>
  </div>
</div>

<!-- ALERTS UNSAVED MODAL -->
<div id="alerts-unsaved-modal" class="pm-modal-overlay" style="display:none;">
  <div class="pm-modal-box" style="width:420px;">
    <div class="pm-modal-header">
      <span style="font-size:16px;font-weight:600;color:var(--color-text-primary);">Unsaved Changes</span>
    </div>
    <div class="pm-modal-body">
      <p style="font-size:14px;color:var(--color-text-primary);margin:0;">You've made some updates that haven't been saved yet. If you leave now, you'll lose these changes.</p>
    </div>
    <div class="pm-modal-footer" style="display:flex;gap:10px;justify-content:flex-end;">
      <button class="btn-primary-sm" onclick="alertsStay()">Stay</button>
      <button style="background:#d72225;color:white;border:none;border-radius:8px;padding:8px 18px;font-size:14px;font-family:'DM Sans',sans-serif;font-weight:500;cursor:pointer;" onclick="alertsDiscard()">Discard</button>
    </div>
  </div>
</div>

<!-- ══ PERMISSION MANAGER: Role / Client Access Modal ══ -->
<div id="pm-role-modal" class="pm-modal-overlay" style="display:none;" onclick="pmModalOverlayClick(event)">
  <div class="pm-modal-box" onclick="event.stopPropagation()">
    <div class="pm-modal-header">
      <div>
        <h3 class="modal-title" id="pm-modal-username" style="margin-bottom:4px;"></h3>
        <p class="modal-desc" id="pm-modal-subtitle"></p>
      </div>
      <button onclick="pmCloseModal()" style="background:none;border:none;cursor:pointer;font-size:22px;color:var(--color-text-caption);padding:0;line-height:1;flex-shrink:0;">×</button>
    </div>
    <div id="pm-modal-tabs" style="display:flex;border-bottom:1px solid var(--color-border);padding:0 24px;margin-top:16px;flex-shrink:0;">
      <button class="detail-tab active" data-pmtab="roles" onclick="pmSwitchModalTab('roles')">Roles</button>
      <button class="detail-tab" data-pmtab="clients" onclick="pmSwitchModalTab('clients')">Client Access</button>
    </div>
    <div class="pm-modal-body">
      <div id="pm-modal-tab-roles" style="padding-top:20px;">
        <div id="pm-modal-roles-cards"></div>
      </div>
      <div id="pm-modal-tab-clients" style="display:none;padding-top:20px;">
        <h4 style="font-size:14px;font-weight:600;color:var(--color-text-primary);margin:0 0 4px;" id="pm-ca-title"></h4>
        <p style="font-size:13px;color:var(--color-text-subtitle);margin:0 0 16px;">Choose which clients this user should have access to</p>
        <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--color-border);margin-bottom:14px;">
          <span style="font-size:14px;font-weight:500;color:var(--color-text-primary);">User has access to all clients by default</span>
          <label class="toggle-switch">
            <input type="checkbox" id="pm-ca-all-toggle" onchange="pmToggleAllAccess(this.checked)">
            <span class="toggle-slider"></span>
          </label>
        </div>
        <div id="pm-ca-client-section" style="display:none;">
          <div class="modal-label" style="margin-bottom:6px;">Clients</div>
          <div class="pm-client-list" id="pm-ca-client-list"></div>
        </div>
        <div class="pm-unsaved-banner" id="pm-unsaved-banner" style="display:none;">
          You've made some updates that haven't been saved yet. If you leave now, you'll lose these changes.
          <div style="display:flex;gap:8px;margin-top:10px;">
            <button class="btn-primary-sm" onclick="pmStayOnModal()" style="height:32px;font-size:13px;">Stay</button>
            <button onclick="pmDiscardAndClose()" style="height:32px;font-size:13px;padding:0 14px;background:#fff0f0;color:#d72225;border:1px solid #d72225;border-radius:8px;cursor:pointer;font-family:'Inter',sans-serif;font-weight:500;">Discard</button>
          </div>
        </div>
      </div>
    </div>
    <div class="pm-modal-footer" id="pm-modal-footer" style="display:none;">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="pmCloseModal()">Cancel</button>
      <button id="pm-modal-save" class="btn-primary-sm pm-btn-disabled" onclick="pmSaveModal()">Save Changes</button>
    </div>
  </div>
</div>

<!-- Permission Manager ⋮ Action Dropdown -->
<div id="pm-action-dd" style="display:none;">
  <div class="pm-dd-item" onclick="pmMenuAction('edit')">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
    Edit Roles
  </div>
  <div class="pm-dd-item" onclick="pmMenuAction('view')">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
    View Roles
  </div>
  <div class="pm-dd-item" onclick="pmMenuAction('clients')">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
