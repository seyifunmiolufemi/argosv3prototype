<!-- ══ ADD EXPORT PAGE ══ -->
<div id="add-export-page" style="display:none;">
  <div class="page-title-row">
    <div class="page-title-left">
      <h1 class="page-h1">Add Export</h1>
      <p class="page-subtitle" style="text-align:left;">Set up your export settings</p>
    </div>
  </div>
  <nav class="breadcrumb" style="margin-bottom:16px;">
    <span class="bc-item bc-muted">Tools</span><span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showFeedDataPage()">Feed Data Tool</span><span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showDbOverviewPage()">Feed Database</span><span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showDbOverviewPage();switchDbTab('exports')">Exports</span><span class="bc-item bc-muted">›</span>
    <span class="bc-item">Add Export</span>
  </nav>

  <!-- Wizard tabs -->
  <div class="detail-tabs-bar" id="export-wizard-tabs-bar" style="margin-bottom:24px;">
    <button class="detail-tab active" data-exporttab="1">General</button>
    <button class="detail-tab" data-exporttab="2">Connection</button>
    <button class="detail-tab" data-exporttab="3">Schedule</button>
    <button class="detail-tab" data-exporttab="4">Filters</button>
    <button class="detail-tab" data-exporttab="5">Field Mapping</button>
  </div>

  <!-- Step 1: General -->
  <div class="wizard-step active" id="export-step-1">
    <div style="max-width:520px;">
      <div style="margin-bottom:16px;">
        <label class="field-label">Export Name <span class="field-required">*</span></label>
        <input type="text" id="export-name-input" class="modal-input" placeholder="e.g. Google Shopping Feed">
      </div>
      <div style="margin-bottom:16px;">
        <label class="field-label">Destination <span class="field-required">*</span></label>
        <select class="modal-select" id="export-destination-select">
          <option value="">Select destination</option>
          <option>Google Merchant Center</option>
          <option>Microsoft Ads</option>
          <option>Meta / Facebook</option>
          <option>Reddit</option>
          <option>SFTP</option>
          <option>FTP</option>
          <option>Custom URL</option>
        </select>
      </div>
      <div style="margin-bottom:16px;">
        <label class="field-label">File Name <span class="field-required">*</span></label>
        <input type="text" class="modal-input" placeholder="e.g. products-feed">
      </div>
      <div style="margin-bottom:16px;">
        <label class="field-label">File Format <span class="field-required">*</span></label>
        <select class="modal-select"><option>CSV</option><option>TSV</option><option>XML</option><option>TXT</option></select>
      </div>
      <div style="margin-bottom:16px;">
        <label class="field-label">Compression <span class="field-required">*</span></label>
        <select class="modal-select"><option>None</option><option>Gzip</option><option>Zip</option></select>
      </div>
      <div style="margin-bottom:16px;">
        <label class="field-label">Rule Delimiter <span class="field-required">*</span></label>
        <select class="modal-select"><option>Tab</option><option>Comma</option><option>Pipe</option><option>Semicolon</option></select>
      </div>
    </div>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="hideAddExportPage();showDbOverviewPage();switchDbTab('exports')">Back</button>
      <button class="btn-primary-sm" onclick="goExportStep(2)">Next</button>
      <button class="btn-text-link grey" onclick="hideAddExportPage();showDbOverviewPage();switchDbTab('exports')">Cancel</button>
    </div>
  </div>

  <!-- Step 2: Connection -->
  <div class="wizard-step" id="export-step-2" style="display:none;">
    <div style="max-width:520px;">
      <div style="margin-bottom:16px;">
        <label class="field-label">Google Merchant Center ID <span class="field-required">*</span></label>
        <input type="text" class="modal-input" placeholder="e.g. 123456789">
        <button class="btn-text-link" style="margin-top:8px;" onclick="showToast('Testing connection...')">Test Connection</button>
      </div>
    </div>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="goExportStep(1)">Back</button>
      <button class="btn-primary-sm" onclick="goExportStep(3)">Next</button>
      <button class="btn-text-link grey" onclick="hideAddExportPage();showDbOverviewPage();switchDbTab('exports')">Cancel</button>
    </div>
  </div>

  <!-- Step 3: Schedule -->
  <div class="wizard-step" id="export-step-3" style="display:none;">
    <div style="max-width:520px;">
      <div style="margin-bottom:16px;">
        <label class="field-label">Frequency <span class="field-required">*</span></label>
        <select class="modal-select"><option>Hourly</option><option selected>Every 6 hours</option><option>Every 12 hours</option><option>Daily</option><option>Weekly</option><option>Custom</option></select>
      </div>
      <div style="margin-bottom:16px;">
        <label class="field-label">Time <span class="field-required">*</span></label>
        <select class="modal-select">
          <option>12:00 AM</option><option>1:00 AM</option><option>2:00 AM</option><option>3:00 AM</option><option>4:00 AM</option><option>5:00 AM</option>
          <option selected>6:00 AM</option><option>7:00 AM</option><option>8:00 AM</option><option>9:00 AM</option><option>10:00 AM</option><option>11:00 AM</option>
          <option>12:00 PM</option><option>1:00 PM</option><option>2:00 PM</option><option>3:00 PM</option><option>4:00 PM</option><option>5:00 PM</option>
          <option>6:00 PM</option><option>7:00 PM</option><option>8:00 PM</option><option>9:00 PM</option><option>10:00 PM</option><option>11:00 PM</option>
        </select>
      </div>
      <div style="margin-bottom:16px;">
        <label class="field-label">Time Zone <span class="field-required">*</span></label>
        <select class="modal-select">
          <option selected>New York City, United States (EST, UTC -05:00)</option>
          <option>Los Angeles, United States (PST, UTC -08:00)</option>
          <option>Chicago, United States (CST, UTC -06:00)</option>
          <option>London, United Kingdom (GMT, UTC +00:00)</option>
        </select>
      </div>
    </div>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="goExportStep(2)">Back</button>
      <button class="btn-primary-sm" onclick="goExportStep(4)">Next</button>
      <button class="btn-text-link grey" onclick="hideAddExportPage();showDbOverviewPage();switchDbTab('exports')">Cancel</button>
    </div>
  </div>

  <!-- Step 4: Filters -->
  <div class="wizard-step" id="export-step-4" style="display:none;">
    <div style="max-width:600px;">
      <div class="section-block" style="border-top:none;margin-top:0;padding-top:0;">
        <div class="section-block-title">Product Filters</div>
        <div class="section-block-sub">Only export products that match ALL these conditions.</div>
        <table class="filter-table" style="margin-top:8px;">
          <tbody id="export-filter-tbody">
            <tr>
              <td style="color:var(--color-text-caption);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;padding-bottom:6px;">Field</td>
              <td style="color:var(--color-text-caption);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;padding-bottom:6px;">Operator</td>
              <td style="color:var(--color-text-caption);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;padding-bottom:6px;">Value</td>
              <td style="width:36px;"></td>
            </tr>
            <tr>
              <td><select class="modal-select" style="padding:7px 10px;font-size:13px;"><option>title</option><option>id</option><option>brand</option><option>availability</option><option>price</option></select></td>
              <td><select class="modal-select" style="padding:7px 10px;font-size:13px;"><option>contains</option><option selected>is not empty</option><option>equals</option><option>starts with</option></select></td>
              <td><input type="text" class="modal-input" placeholder="Value" style="padding:7px 10px;font-size:13px;"></td>
              <td><button onclick="this.closest('tr').remove()" class="btn-danger-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg></button></td>
            </tr>
          </tbody>
        </table>
        <button class="btn-text-link" style="margin-top:6px;" onclick="showToast('Filter added')">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Filter
        </button>
      </div>
      <div class="section-block">
        <div class="section-block-title">Safety Thresholds</div>
        <div style="margin-bottom:12px;">
          <label style="display:flex;align-items:flex-start;gap:8px;cursor:pointer;">
            <input type="checkbox" checked style="margin-top:2px;">
            <div>
              <div style="font-size:13px;font-weight:500;color:var(--color-text-primary);">Minimum product count</div>
              <div style="font-size:12px;color:var(--color-text-caption);margin-bottom:8px;">Only export if the total number of products meets a minimum</div>
              <div style="display:flex;align-items:center;gap:8px;">
                <span style="font-size:13px;color:var(--color-text-caption);">Product count must be:</span>
                <select class="modal-select" style="padding:5px 8px;font-size:13px;width:auto;"><option>greater than</option><option>equal to</option></select>
                <input type="number" class="modal-input" value="20000" style="padding:5px 8px;font-size:13px;width:90px;">
              </div>
            </div>
          </label>
        </div>
        <div>
          <label style="display:flex;align-items:flex-start;gap:8px;cursor:pointer;">
            <input type="checkbox" checked style="margin-top:2px;">
            <div>
              <div style="font-size:13px;font-weight:500;color:var(--color-text-primary);">Threshold protection</div>
              <div style="font-size:12px;color:var(--color-text-caption);margin-bottom:8px;">Block export if product count drops significantly from last export</div>
              <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                <span style="font-size:13px;color:var(--color-text-caption);">Block export if count drops below:</span>
                <input type="number" class="modal-input" value="90" style="padding:5px 8px;font-size:13px;width:70px;">
                <span style="font-size:13px;color:var(--color-text-caption);">% of last export</span>
              </div>
            </div>
          </label>
        </div>
      </div>
    </div>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="goExportStep(3)">Back</button>
      <button class="btn-primary-sm" onclick="goExportStep(5)">Next</button>
      <button class="btn-text-link grey" onclick="hideAddExportPage();showDbOverviewPage();switchDbTab('exports')">Cancel</button>
    </div>
  </div>

  <!-- Step 5: Field Mapping -->
  <div class="wizard-step" id="export-step-5" style="display:none;">
    <p style="font-size:13px;color:var(--color-text-caption);margin:0 0 14px;">Map your database fields to export column names</p>
    <div class="table-card" style="padding:0;overflow:hidden;max-width:640px;">
      <div class="table-scroll">
        <table class="fm-table">
          <colgroup><col style="width:38%;"><col style="width:38%;"><col style="width:24%;"></colgroup>
          <thead><tr><th>Database Field</th><th>Export Name</th><th>Action</th></tr></thead>
          <tbody id="export-fm-tbody">
            <tr><td><select class="modal-select" style="padding:6px 9px;font-size:13px;"><option>id</option><option>title</option><option>description</option><option>link</option><option>image_link</option><option>price</option><option>sale_price</option><option>brand</option><option>condition</option><option>availability</option><option>product_type</option></select></td><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="id" style="padding:6px 9px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
            <tr><td><select class="modal-select" style="padding:6px 9px;font-size:13px;"><option>id</option><option selected>title</option><option>description</option><option>link</option><option>image_link</option><option>price</option><option>sale_price</option><option>brand</option></select></td><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="title" style="padding:6px 9px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
            <tr><td><select class="modal-select" style="padding:6px 9px;font-size:13px;"><option>id</option><option>title</option><option selected>description</option><option>link</option><option>image_link</option><option>price</option><option>sale_price</option><option>brand</option></select></td><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="description" style="padding:6px 9px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
            <tr><td><select class="modal-select" style="padding:6px 9px;font-size:13px;"><option>id</option><option>title</option><option>description</option><option selected>link</option><option>image_link</option><option>price</option><option>sale_price</option><option>brand</option></select></td><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="link" style="padding:6px 9px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
            <tr><td><select class="modal-select" style="padding:6px 9px;font-size:13px;"><option>id</option><option>title</option><option>description</option><option>link</option><option selected>image_link</option><option>price</option><option>sale_price</option><option>brand</option></select></td><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="image_link" style="padding:6px 9px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
            <tr><td><select class="modal-select" style="padding:6px 9px;font-size:13px;"><option>id</option><option>title</option><option>description</option><option>link</option><option>image_link</option><option selected>price</option><option>sale_price</option><option>brand</option></select></td><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="price" style="padding:6px 9px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
            <tr><td><select class="modal-select" style="padding:6px 9px;font-size:13px;"><option>id</option><option>title</option><option>description</option><option>link</option><option>image_link</option><option>price</option><option>sale_price</option><option selected>brand</option></select></td><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="brand" style="padding:6px 9px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <button class="btn-text-link" style="margin-top:8px;" onclick="showToast('Field mapping row added')">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Field Mapping
    </button>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="goExportStep(4)">Back</button>
      <button class="btn-primary-sm" onclick="createExport()">Create Export</button>
      <button class="btn-text-link grey" onclick="hideAddExportPage();showDbOverviewPage();switchDbTab('exports')">Cancel</button>
    </div>
  </div>
</div><!-- /add-export-page -->

<!-- ══ PERMISSION MANAGER ══ -->
<div id="permission-manager-page" style="display:none;">

  <!-- ── List view ── -->
  <div id="pm-list-view">
    <div class="page-title-row">
      <div>
        <h1 class="page-h1" style="font-size:18px;">Permission Manager</h1>
        <p class="page-subtitle" style="margin-top:3px;">Manage what each role can access across Statbid.</p>
      </div>
      <div class="page-title-right">
        <button class="btn-primary-sm" onclick="pmShowAssignView()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Assign Role
        </button>
      </div>
    </div>
    <div class="breadcrumb" style="margin-bottom:14px;">
      <span class="bc-item bc-muted">User Management</span>
      <span class="bc-item bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item">Permission Manager</span>
    </div>
    <div class="search-box" style="margin-bottom:16px;max-width:100%;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="pm-search" placeholder="Search users" oninput="pmSearch()">
    </div>
    <div class="table-card" style="padding:0;overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="border-bottom:1px solid var(--color-border);">
            <th style="padding:10px 16px;font-size:11px;font-weight:600;color:var(--color-text-accent);letter-spacing:0.5px;text-transform:uppercase;text-align:left;">USER <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left:3px;vertical-align:middle;"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg></th>
            <th style="padding:10px 16px;font-size:11px;font-weight:600;color:var(--color-text-accent);letter-spacing:0.5px;text-transform:uppercase;text-align:left;">ROLE <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left:3px;vertical-align:middle;"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg></th>
            <th style="padding:10px 16px;font-size:11px;font-weight:600;color:var(--color-text-accent);letter-spacing:0.5px;text-transform:uppercase;text-align:left;">LAST MODIFIED <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left:3px;vertical-align:middle;"><path d="M7 15l5 5 5-5M7 9l5-5 5 5"/></svg></th>
            <th style="padding:10px 16px;font-size:11px;font-weight:600;color:var(--color-text-accent);letter-spacing:0.5px;text-transform:uppercase;text-align:center;">ACTION</th>
          </tr>
        </thead>
        <tbody id="pm-users-tbody">
        </tbody>
      </table>
    </div>
  </div><!-- /pm-list-view -->

  <!-- ── Assign Role view ── -->
  <div id="pm-assign-view" style="display:none;">
    <div class="page-title-row">
      <h1 class="page-h1" style="font-size:18px;">Permission Manager</h1>
    </div>
    <div class="breadcrumb" style="margin-bottom:14px;">
      <span class="bc-item bc-muted">User Management</span>
      <span class="bc-item bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item">Permission Manager</span>
    </div>
    <div class="table-card">
      <h2 style="font-size:16px;font-weight:600;color:var(--color-text-primary);margin:0 0 4px;">Assign Role</h2>
      <p style="font-size:13px;color:var(--color-text-subtitle);margin:0 0 20px;">Choose a user and assign a role in Statbid</p>
      <div style="margin-bottom:20px;">
        <div class="modal-label" style="margin-bottom:6px;">Select User</div>
        <div style="position:relative;">
          <div class="search-box">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="pm-assign-search" placeholder="Search users" autocomplete="off" oninput="pmAssignSearch()">
          </div>
          <div class="pm-user-search-dd" id="pm-assign-dd"></div>
        </div>
        <div id="pm-selected-chips" style="margin-top:8px;min-height:8px;"></div>
      </div>
      <div style="margin-bottom:24px;">
        <div class="modal-label" style="margin-bottom:10px;">Select Role</div>
        <div id="pm-assign-roles"></div>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <button id="pm-assign-submit" class="btn-primary-sm pm-btn-disabled" onclick="pmSubmitAssign()">Assign Role</button>
        <button class="btn-outline" style="height:36px;padding:0 16px;" onclick="pmBackToList()">Cancel</button>
      </div>
    </div>
  </div><!-- /pm-assign-view -->

</div><!-- /permission-manager-page -->

<!-- ═══════════════════════════════════════════
     ANNOTATIONS PAGE
═══════════════════════════════════════════ -->
<div id="annotations-page" style="display:none; padding:32px 32px 64px;">

  <!-- LIST VIEW -->
  <div id="ann-list-view">
    <div class="page-title-row" style="margin-bottom:4px;">
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <h1 class="page-h1">Annotations</h1>
        <span class="count-badge" id="ann-count-badge">10</span>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <button class="btn-primary-sm" onclick="annShowAddView()" style="display:flex;align-items:center;gap:6px;">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Add Annotation
        </button>
      </div>
    </div>
    <p class="page-subtitle" style="margin-bottom:20px;">Track campaign events, site changes, and other notes tied to specific dates.</p>
    <nav class="breadcrumb" style="margin-bottom:20px;">
      <span class="bc-item bc-muted">Tools</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item" style="color:var(--color-text-primary);">Annotations</span>
    </nav>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
      <div style="position:relative;flex:1;max-width:320px;">
        <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);pointer-events:none;" width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="4.5" stroke="var(--color-text-caption)" stroke-width="1.3"/><path d="M10 10l2.5 2.5" stroke="var(--color-text-caption)" stroke-width="1.3" stroke-linecap="round"/></svg>
        <input id="ann-search" class="search-box" style="padding-left:32px;width:100%;box-sizing:border-box;" placeholder="Search annotations…" oninput="annSearch()">
      </div>
    </div>
    <div class="table-card">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="background:var(--color-bg-grey50);border-bottom:1px solid var(--color-border);">
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Title ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Client ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Website ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Date ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Last Modified ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:center;">Action</th>
          </tr>
        </thead>
        <tbody id="ann-tbody"></tbody>
      </table>
    </div>
  </div><!-- /ann-list-view -->

  <!-- ADD ANNOTATION VIEW -->
  <div id="ann-add-view" style="display:none;">
    <div class="page-title-row" style="margin-bottom:4px;">
      <h1 class="page-h1">Add Annotation</h1>
    </div>
    <p class="page-subtitle" style="margin-bottom:20px;">Add a new annotation to track a campaign event or site change.</p>
    <nav class="breadcrumb" style="margin-bottom:24px;">
      <span class="bc-item bc-muted">Tools</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item bc-muted" style="cursor:pointer;" onclick="annShowListView()">Annotations</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item" style="color:var(--color-text-primary);">Add Annotation</span>
    </nav>
    <div style="max-width:649px;">
      <div class="table-card" style="padding:24px 28px;">
        <!-- Client & Website -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
          <div>
            <label class="field-label">Client <span style="color:#d72225;">*</span></label>
            <select class="modal-select" id="ann-form-client" onchange="annOnClientChange()" style="width:100%;">
              <option value="">Select Client</option>
              <option>MojoMotoSport</option><option>Blossom Beauty</option><option>Peak Performance</option>
              <option>Coastal Living</option><option>Urban Threads</option><option>Bright Minds</option>
              <option>Terra Gardens</option><option>Apex Fitness</option><option>Silver Creek</option>
              <option>Harbor Light</option><option>Sunset Brands</option><option>Blue Ridge Co.</option>
              <option>Crestwood Market</option><option>Elm &amp; Oak</option><option>Frost &amp; Co.</option>
              <option>Golden Gate Goods</option><option>Hillside Home</option><option>Iron Ridge</option>
              <option>Juniper Lane</option><option>Keystone Shop</option><option>Lakeside Living</option>
              <option>Maple Grove</option><option>Northpoint</option><option>Orchard Street</option>
              <option>Pinecrest Supply</option><option>Quarry Stone</option><option>Ridgeline Retail</option>
              <option>Summit Supply</option><option>Thornwood Co.</option><option>Upland Goods</option>
              <option>Valley View</option><option>Westbrook</option>
            </select>
          </div>
          <div>
            <label class="field-label">Website <span style="color:#d72225;">*</span></label>
            <select class="modal-select" id="ann-form-website" disabled style="width:100%;opacity:0.6;">
              <option value="">Select Website</option>
            </select>
          </div>
        </div>
        <hr class="form-hr">
        <!-- Date -->
        <div style="margin-bottom:16px;">
          <label class="field-label">Date <span style="color:#d72225;">*</span></label>
          <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
            <input type="date" class="modal-input" id="ann-form-date" style="width:180px;">
            <span id="ann-add-end-link" style="font-size:13px;color:var(--color-blue);cursor:pointer;" onclick="annToggleEndDate(true)">+ Add end date (optional)</span>
          </div>
          <div id="ann-end-date-row" style="display:none;align-items:center;gap:8px;margin-top:8px;">
            <span style="font-size:13px;color:var(--color-text-caption);">to</span>
            <input type="date" class="modal-input" id="ann-form-end-date" style="width:180px;">
            <span style="font-size:13px;color:#d72225;cursor:pointer;" onclick="annToggleEndDate(false)">× Remove</span>
          </div>
        </div>
        <hr class="form-hr">
        <!-- Title -->
        <div style="margin-bottom:16px;">
          <label class="field-label">Title <span style="color:#d72225;">*</span></label>
          <input type="text" class="modal-input" id="ann-form-title" placeholder="e.g. Black Friday campaign launched" style="width:100%;box-sizing:border-box;">
        </div>
        <!-- Notes -->
        <div style="margin-bottom:24px;">
          <label class="field-label">Additional Notes</label>
          <textarea class="modal-textarea" id="ann-form-notes" placeholder="Optional notes about this annotation…" rows="3" style="width:100%;box-sizing:border-box;resize:vertical;"></textarea>
        </div>
        <!-- Buttons -->
        <div style="display:flex;gap:10px;align-items:center;">
          <button class="btn-primary-sm" onclick="annSubmitAdd()">Add Annotation</button>
          <button class="btn-outline" onclick="annShowListView()">Cancel</button>
        </div>
      </div>
    </div>
  </div><!-- /ann-add-view -->

  <!-- DETAIL / EDIT VIEW -->
  <div id="ann-detail-view" style="display:none;">
    <div class="page-title-row" style="margin-bottom:4px;align-items:flex-start;">
      <div>
        <h1 class="page-h1" id="ann-detail-heading">Annotation</h1>
      </div>
      <div id="ann-detail-edit-btns" style="display:flex;gap:8px;align-items:center;">
        <button class="btn-primary-sm" onclick="annEnableEdit()">Edit</button>
        <button class="btn-outline" style="border-color:#d72225;color:#d72225;" onclick="annConfirmDelete(_annActiveId)">Delete</button>
      </div>
      <div id="ann-detail-save-btns" style="display:none;gap:8px;align-items:center;">
        <button class="btn-primary-sm" onclick="annSaveEdit()">Save Changes</button>
        <button class="btn-outline" onclick="annCancelEdit()">Cancel</button>
      </div>
    </div>
    <nav class="breadcrumb" style="margin-bottom:8px;">
      <span class="bc-item bc-muted">Tools</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item bc-muted" style="cursor:pointer;" onclick="annShowListView()">Annotations</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item" id="ann-detail-bc-title" style="color:var(--color-text-primary);">Detail</span>
    </nav>
    <p id="ann-detail-modified" style="font-size:12px;color:var(--color-text-caption);margin-bottom:24px;"></p>
    <div style="max-width:649px;">
      <div class="table-card" style="padding:24px 28px;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
          <div>
            <label class="field-label">Client</label>
            <select class="modal-select" id="ann-detail-client-input" style="width:100%;" disabled>
              <option value="">Select Client</option>
              <option>MojoMotoSport</option><option>Blossom Beauty</option><option>Peak Performance</option>
              <option>Coastal Living</option><option>Urban Threads</option><option>Bright Minds</option>
              <option>Terra Gardens</option><option>Apex Fitness</option><option>Silver Creek</option>
              <option>Harbor Light</option><option>Sunset Brands</option><option>Blue Ridge Co.</option>
              <option>Crestwood Market</option><option>Elm &amp; Oak</option><option>Frost &amp; Co.</option>
              <option>Golden Gate Goods</option><option>Hillside Home</option><option>Iron Ridge</option>
              <option>Juniper Lane</option><option>Keystone Shop</option><option>Lakeside Living</option>
              <option>Maple Grove</option><option>Northpoint</option><option>Orchard Street</option>
              <option>Pinecrest Supply</option><option>Quarry Stone</option><option>Ridgeline Retail</option>
              <option>Summit Supply</option><option>Thornwood Co.</option><option>Upland Goods</option>
              <option>Valley View</option><option>Westbrook</option>
            </select>
          </div>
          <div>
            <label class="field-label">Website</label>
            <select class="modal-select" id="ann-detail-website-input" style="width:100%;" disabled>
              <option value="">Select Website</option>
              <option>MojoMotoSport</option><option>Blossom Beauty</option><option>Peak Performance</option>
              <option>Coastal Living</option><option>Urban Threads</option><option>Bright Minds</option>
              <option>Terra Gardens</option><option>Apex Fitness</option><option>Silver Creek</option>
              <option>Harbor Light</option><option>Sunset Brands</option><option>Blue Ridge Co.</option>
              <option>Crestwood Market</option><option>Elm &amp; Oak</option><option>Frost &amp; Co.</option>
              <option>Golden Gate Goods</option><option>Hillside Home</option><option>Iron Ridge</option>
              <option>Juniper Lane</option><option>Keystone Shop</option><option>Lakeside Living</option>
              <option>Maple Grove</option><option>Northpoint</option><option>Orchard Street</option>
              <option>Pinecrest Supply</option><option>Quarry Stone</option><option>Ridgeline Retail</option>
              <option>Summit Supply</option><option>Thornwood Co.</option><option>Upland Goods</option>
              <option>Valley View</option><option>Westbrook</option>
            </select>
          </div>
        </div>
        <hr class="form-hr">
        <div style="margin-bottom:16px;">
          <label class="field-label">Date</label>
          <input type="date" class="modal-input" id="ann-detail-date-input" style="width:180px;" disabled>
        </div>
        <hr class="form-hr">
        <div style="margin-bottom:16px;">
          <label class="field-label">Title</label>
          <input type="text" class="modal-input" id="ann-detail-title-input" style="width:100%;box-sizing:border-box;" disabled>
        </div>
        <div>
          <label class="field-label">Additional Notes</label>
          <textarea class="modal-textarea" id="ann-detail-notes-input" rows="3" style="width:100%;box-sizing:border-box;resize:vertical;" disabled></textarea>
        </div>
      </div>
    </div>
  </div><!-- /ann-detail-view -->

</div><!-- /annotations-page -->

<!-- ═══════════════════════════════════════════
     ALERTS PAGE
═══════════════════════════════════════════ -->
<div id="alerts-page" style="display:none; padding:32px 32px 64px;">

  <!-- LIST VIEW -->
  <div id="alerts-list-view">
    <div class="page-title-row" style="margin-bottom:4px;">
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <h1 class="page-h1">Alerts Management</h1>
        <span class="count-badge" id="alerts-count-badge">9</span>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <button class="btn-primary-sm" onclick="alertsShowCreate(null)" style="display:flex;align-items:center;gap:6px;">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Create Alert
        </button>
      </div>
    </div>
    <p class="page-subtitle" style="margin-bottom:20px;">Set up automated alerts to monitor key metrics and get notified when thresholds are breached.</p>
    <nav class="breadcrumb" style="margin-bottom:20px;">
      <span class="bc-item bc-muted">Tools</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item" style="color:var(--color-text-primary);">Alerts Management</span>
    </nav>
    <!-- Filter bar -->
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
      <div style="position:relative;flex:1;max-width:280px;">
        <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);pointer-events:none;" width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="4.5" stroke="var(--color-text-caption)" stroke-width="1.3"/><path d="M10 10l2.5 2.5" stroke="var(--color-text-caption)" stroke-width="1.3" stroke-linecap="round"/></svg>
        <input id="alerts-search" class="search-box" style="padding-left:32px;width:100%;box-sizing:border-box;" placeholder="Search alerts…" oninput="alertsSearch()">
      </div>
      <div id="alerts-ds-wrap" style="position:relative;">
        <button class="btn-filter" onclick="document.getElementById('alerts-ds-panel').classList.toggle('open');document.getElementById('alerts-status-panel').classList.remove('open');" style="display:flex;align-items:center;gap:6px;min-width:160px;justify-content:space-between;">
          <span id="alerts-ds-btn-label">Data Source: All</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="alerts-ds-panel" class="alerts-filter-panel">
          <div class="alerts-filter-item" onclick="alertsSetFilterDs('','')">All</div>
          <div class="alerts-filter-item" onclick="alertsSetFilterDs('Google Ads','')">Google Ads</div>
          <div class="alerts-filter-item" onclick="alertsSetFilterDs('Meta Ads','')">Meta Ads</div>
          <div class="alerts-filter-item" onclick="alertsSetFilterDs('Organic Search (SEO)','')">Organic Search (SEO)</div>
          <div class="alerts-filter-item" onclick="alertsSetFilterDs('Microsoft Ads','')">Microsoft Ads</div>
        </div>
      </div>
      <div id="alerts-status-wrap" style="position:relative;">
        <button class="btn-filter" onclick="document.getElementById('alerts-status-panel').classList.toggle('open');document.getElementById('alerts-ds-panel').classList.remove('open');" style="display:flex;align-items:center;gap:6px;min-width:130px;justify-content:space-between;">
          <span id="alerts-status-btn-label">Status: All</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="alerts-status-panel" class="alerts-filter-panel">
          <div class="alerts-filter-item" onclick="alertsSetFilterStatus('')">All</div>
          <div class="alerts-filter-item" onclick="alertsSetFilterStatus('Active')">Active</div>
          <div class="alerts-filter-item" onclick="alertsSetFilterStatus('Draft')">Draft</div>
        </div>
      </div>
    </div>
    <div class="table-card">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="background:var(--color-bg-grey50);border-bottom:1px solid var(--color-border);">
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Alert ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Data Source ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Scope ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Status ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Last Run ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Last Triggered ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Last Modified ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:center;">Action</th>
          </tr>
        </thead>
        <tbody id="alerts-tbody"></tbody>
      </table>
    </div>
  </div><!-- /alerts-list-view -->

  <!-- CREATE ALERT VIEW -->
  <div id="alerts-create-view" style="display:none;">
    <div class="page-title-row" style="margin-bottom:4px;">
      <h1 class="page-h1" id="alerts-create-heading">Create Alert</h1>
    </div>
    <p class="page-subtitle" style="margin-bottom:20px;">Configure the conditions, schedule, and notification settings for your alert.</p>
    <nav class="breadcrumb" style="margin-bottom:24px;">
      <span class="bc-item bc-muted">Tools</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item bc-muted" style="cursor:pointer;" onclick="alertsBackToList()">Alerts Management</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item" id="alerts-create-bc-label" style="color:var(--color-text-primary);">Create Alert</span>
    </nav>
    <div style="max-width:680px;">
      <div class="table-card" style="padding:24px 28px;">

        <!-- Alert Identity -->
        <span class="form-section-label" style="margin-top:0;">Alert Identity</span>
        <div style="margin-bottom:16px;">
          <label class="field-label">Alert Name <span style="color:#d72225;">*</span></label>
          <input type="text" class="modal-input" id="alerts-form-name" placeholder="e.g. Budget Alert" style="width:100%;box-sizing:border-box;" oninput="alertsFormDirty();alertsUpdateCreateBtn()">
        </div>

        <hr class="form-hr">

        <!-- Data Source -->
        <span class="form-section-label">Data Source</span>
        <div style="margin-bottom:16px;">
          <label class="field-label">Data Source <span style="color:#d72225;">*</span></label>
          <select class="modal-select" id="alerts-form-ds" onchange="alertsFormDirty();alertsOnDataSourceChange()" style="width:100%;">
            <option value="">Select Data Source</option>
            <option>Google Ads</option>
            <option>Meta Ads</option>
            <option>Organic Search (SEO)</option>
            <option>Microsoft Ads</option>
          </select>
        </div>

        <hr class="form-hr">

        <!-- Scope -->
        <span class="form-section-label">Scope</span>
        <div style="margin-bottom:8px;">
          <label class="field-label">Apply To <span style="color:#d72225;">*</span></label>
          <div class="scope-radio-group">
            <div class="scope-radio-option selected" data-scope="All Clients" onclick="alertsSelectScope(this)">
              <span class="scope-radio-dot"></span>All Clients
            </div>
            <div class="scope-radio-option" data-scope="Specific Clients" onclick="alertsSelectScope(this)">
              <span class="scope-radio-dot"></span>Specific Clients
            </div>
          </div>
        </div>
        <div id="alerts-client-select-row" style="display:none;margin-top:10px;margin-bottom:8px;">
          <label class="field-label">Select Clients</label>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;" id="alerts-client-chips"></div>
          <select class="modal-select" id="alerts-client-dd" onchange="alertsAddClient(this.value);this.value='';" style="width:240px;">
            <option value="">+ Add client…</option>
            <option>MojoMotoSport</option><option>Blossom Beauty</option><option>Peak Performance</option>
            <option>Coastal Living</option><option>Urban Threads</option><option>Bright Minds</option>
            <option>Terra Gardens</option><option>Apex Fitness</option><option>Silver Creek</option>
            <option>Harbor Light</option>
          </select>
        </div>

        <hr class="form-hr">

        <!-- Metrics -->
        <span class="form-section-label">Metrics</span>
        <div style="margin-bottom:8px;">
          <label class="field-label">Select Metrics <span style="color:#d72225;">*</span></label>
          <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px;min-height:28px;" id="alerts-metric-chips"></div>
          <div id="alerts-metrics-wrap" style="position:relative;display:inline-block;">
            <button class="btn-filter" id="alerts-metrics-btn" onclick="alertsToggleMetricsPanel()" style="display:flex;align-items:center;gap:6px;">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              Add Metric
            </button>
            <div id="alerts-metrics-panel" class="metrics-dd-panel"></div>
          </div>
        </div>

        <hr class="form-hr">

        <!-- Conditions -->
        <span class="form-section-label">Conditions</span>
        <div id="alerts-conditions-container" style="margin-bottom:8px;">
          <p style="font-size:13px;color:var(--color-text-caption);margin:0;">Select at least one metric to define alert conditions.</p>
        </div>
        <div id="alerts-summary-box" class="alert-summary-box muted" style="margin-bottom:0;">
          Set up the alert conditions in order to view the alert summary.
        </div>

        <hr class="form-hr">

        <!-- Schedule -->
        <span class="form-section-label">Schedule</span>
        <div style="margin-bottom:16px;">
          <label class="field-label">Check Frequency <span style="color:#d72225;">*</span></label>
          <select class="modal-select" id="alerts-form-freq" onchange="alertsFormDirty()" style="width:220px;">
            <option>Daily</option>
            <option>Weekly</option>
            <option>Monthly</option>
          </select>
        </div>

        <hr class="form-hr">

        <!-- Alert Message Preview -->
        <span class="form-section-label">Alert Message Preview</span>
        <p style="font-size:13px;color:var(--color-text-caption);margin:0 0 8px;">
          <span style="color:var(--color-blue);cursor:pointer;text-decoration:underline;" onclick="alertsShowPreview()">Preview alert message</span> — see how the notification will look in Slack.
        </p>

        <hr class="form-hr">

        <!-- Notifications -->
        <span class="form-section-label">Notifications</span>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
          <div>
            <label class="field-label">Slack Channel</label>
            <select class="modal-select" id="alerts-form-slack-ch" onchange="alertsFormDirty()" style="width:100%;">
              <option value="">None</option>
              <option>#alerts-general</option>
              <option>#alerts-budget</option>
              <option>#alerts-performance</option>
              <option>#team-paid-search</option>
            </select>
          </div>
          <div>
            <label class="field-label">Slack DM</label>
            <select class="modal-select" id="alerts-form-slack-dm" onchange="alertsFormDirty()" style="width:100%;">
              <option value="">None</option>
              <option>Shilo Jones</option>
              <option>Seyifunmi Olufemi</option>
              <option>Marcus Reid</option>
              <option>Priya Nair</option>
              <option>Devon Blake</option>
            </select>
          </div>
        </div>

        <!-- Button row -->
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;border-top:1px solid var(--color-border);padding-top:20px;">
          <button class="btn-primary-sm pm-btn-disabled" id="alerts-create-btn" disabled onclick="alertsSubmitCreate()">Create Alert</button>
          <button class="btn-outline" onclick="alertsBackToList()">Cancel</button>
          <button class="btn-outline" style="margin-left:auto;" onclick="alertsShowPreview()">Test Alert</button>
          <button class="btn-outline" onclick="alertsSaveDraft()">Save to Drafts</button>
        </div>

      </div>
    </div>
  </div><!-- /alerts-create-view -->

  <!-- ALERT DETAIL VIEW -->
  <div id="alerts-detail-view" style="display:none;">
    <div class="page-title-row" style="margin-bottom:4px;align-items:flex-start;flex-wrap:wrap;gap:10px;">
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <h1 class="page-h1" id="alerts-detail-heading">Alert</h1>
        <span id="alerts-detail-status"></span>
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
        <button class="btn-outline" id="alerts-detail-toggle-btn" onclick="alertsDetailToggle()">Disable</button>
        <button class="btn-outline" onclick="alertsShowCreate(_alertsActiveId)">Edit</button>
        <button class="btn-outline" onclick="alertsOpenDuplicate(_alertsActiveId)">Duplicate</button>
        <button class="btn-outline" style="border-color:#d72225;color:#d72225;" onclick="alertsConfirmDelete(_alertsActiveId)">Delete</button>
      </div>
    </div>
    <nav class="breadcrumb" style="margin-bottom:8px;">
      <span class="bc-item bc-muted">Tools</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item bc-muted" style="cursor:pointer;" onclick="alertsShowListView()">Alerts Management</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item" id="alerts-detail-bc-title" style="color:var(--color-text-primary);">Detail</span>
    </nav>
    <p id="alerts-detail-modified" style="font-size:12px;color:var(--color-text-caption);margin-bottom:24px;"></p>

    <div style="max-width:700px;">
      <!-- Detail sections rendered by JS -->
      <div id="alerts-detail-sections" class="table-card" style="padding:24px 28px;margin-bottom:20px;"></div>

      <!-- Activity -->
      <div>
        <h2 style="font-size:16px;font-weight:600;color:var(--color-text-primary);margin-bottom:16px;">Alert Activity</h2>
        <div class="table-card">
          <table style="width:100%;border-collapse:collapse;">
            <thead>
              <tr style="background:var(--color-bg-grey50);border-bottom:1px solid var(--color-border);">
                <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Client</th>
                <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Triggered At</th>
                <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Condition</th>
                <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:center;">View</th>
              </tr>
            </thead>
            <tbody id="alerts-activity-tbody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div><!-- /alerts-detail-view -->

</div><!-- /alerts-page -->

<!-- ═══════════════════════════════════════════
     BUSINESS RULE MANAGER PAGE
═══════════════════════════════════════════ -->
<div id="brm-page" style="display:none; padding:32px 32px 64px;">

  <!-- LIST VIEW -->
  <div id="brm-list-view">
    <div class="page-title-row" style="margin-bottom:4px;">
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <h1 class="page-h1">Business Rule Manager</h1>
        <span class="count-badge" id="brm-count-badge">10</span>
      </div>
      <div style="display:flex;gap:8px;align-items:center;">
        <button class="btn-primary-sm" onclick="brmShowCreate()" style="display:flex;align-items:center;gap:6px;">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Create Rule
        </button>
      </div>
    </div>
    <p class="page-subtitle" style="margin-bottom:20px;">Create and manage automated business rules for detecting issues.</p>
    <nav class="breadcrumb" style="margin-bottom:20px;">
      <span class="bc-item bc-muted">Tools</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item" style="color:var(--color-text-primary);">Business Rule Manager</span>
    </nav>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap;">
      <div style="position:relative;flex:1;max-width:280px;">
        <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);pointer-events:none;" width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="4.5" stroke="var(--color-text-caption)" stroke-width="1.3"/><path d="M10 10l2.5 2.5" stroke="var(--color-text-caption)" stroke-width="1.3" stroke-linecap="round"/></svg>
        <input id="brm-search" class="search-box" style="padding-left:32px;width:100%;box-sizing:border-box;" placeholder="Search by rule name…" oninput="brmSearch()">
      </div>
      <div id="brm-ds-wrap" style="position:relative;">
        <button class="btn-filter" onclick="document.getElementById('brm-ds-panel').classList.toggle('open');document.getElementById('brm-status-panel').classList.remove('open');" style="display:flex;align-items:center;gap:6px;min-width:170px;justify-content:space-between;">
          <span id="brm-ds-label">Data Source: All</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="brm-ds-panel" class="alerts-filter-panel">
          <div class="alerts-filter-item" onclick="brmSetDs('')">All</div>
          <div class="alerts-filter-item" onclick="brmSetDs('Google Merchant Center')">Google Merchant Center</div>
          <div class="alerts-filter-item" onclick="brmSetDs('Search Console')">Search Console</div>
          <div class="alerts-filter-item" onclick="brmSetDs('Google Ads')">Google Ads</div>
          <div class="alerts-filter-item" onclick="brmSetDs('Bing Ads')">Bing Ads</div>
          <div class="alerts-filter-item" onclick="brmSetDs('Feed Analyzer')">Feed Analyzer</div>
        </div>
      </div>
      <div id="brm-status-wrap" style="position:relative;">
        <button class="btn-filter" onclick="document.getElementById('brm-status-panel').classList.toggle('open');document.getElementById('brm-ds-panel').classList.remove('open');" style="display:flex;align-items:center;gap:6px;min-width:130px;justify-content:space-between;">
          <span id="brm-status-label">Status: All</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="brm-status-panel" class="alerts-filter-panel">
          <div class="alerts-filter-item" onclick="brmSetStatus('')">All</div>
          <div class="alerts-filter-item" onclick="brmSetStatus('Active')">Active</div>
          <div class="alerts-filter-item" onclick="brmSetStatus('Draft')">Draft</div>
        </div>
      </div>
    </div>
    <div class="table-card">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="background:var(--color-bg-grey50);border-bottom:1px solid var(--color-border);">
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Issue ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Impact ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Data Source ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Entity Type ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Status ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:left;">Last Modified ↕</th>
            <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-accent);padding:10px 16px;text-align:center;">Action</th>
          </tr>
        </thead>
        <tbody id="brm-tbody"></tbody>
      </table>
    </div>
  </div><!-- /brm-list-view -->

  <!-- CREATE VIEW -->
  <div id="brm-create-view" style="display:none;">
    <div class="page-title-row" style="margin-bottom:4px;">
      <h1 class="page-h1" id="brm-create-heading">Create Rule</h1>
    </div>
    <p class="page-subtitle" style="margin-bottom:20px;">Define what the rule is, where it applies, and its context.</p>
    <nav class="breadcrumb" style="margin-bottom:24px;">
      <span class="bc-item bc-muted">Tools</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item bc-muted" style="cursor:pointer;" onclick="brmShowListView()">Business Rule Manager</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item" id="brm-create-bc-label" style="color:var(--color-text-primary);">Create Rule</span>
    </nav>
    <div style="max-width:649px;">
      <div class="table-card" style="padding:24px 28px;">
        <span class="form-section-label" style="margin-top:0;">Rule Details</span>
        <div style="margin-bottom:16px;">
          <label class="field-label">Rule Name <span style="color:#d72225;">*</span> <span title="Enter a descriptive name for this rule" style="display:inline-flex;align-items:center;justify-content:center;width:15px;height:15px;border-radius:50%;background:var(--color-bg-grey25);color:var(--color-text-caption);font-size:10px;cursor:default;margin-left:4px;">?</span></label>
          <input type="text" class="modal-input" id="brm-form-name" placeholder="e.g. Missing Product Titles" style="width:100%;box-sizing:border-box;" oninput="brmUpdateCreateBtn()">
        </div>
        <div style="margin-bottom:16px;">
          <label class="field-label">Rule Description <span style="color:#d72225;">*</span></label>
          <textarea class="modal-textarea" id="brm-form-desc" placeholder="e.g. Detects issues with empty or null fields that could affect user experience" rows="3" style="width:100%;box-sizing:border-box;resize:vertical;min-height:88px;" oninput="brmUpdateCreateBtn()"></textarea>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;">
          <div>
            <label class="field-label">Severity <span style="color:#d72225;">*</span></label>
            <select class="modal-select" id="brm-form-severity" style="width:100%;" onchange="brmUpdateCreateBtn()">
              <option value="High">High</option>
              <option value="Medium" selected>Medium</option>
              <option value="Low">Low</option>
            </select>
          </div>
          <div>
            <label class="field-label">Status</label>
            <select class="modal-select" id="brm-form-status" style="width:100%;">
              <option value="Active" selected>Active</option>
              <option value="Draft">Draft</option>
            </select>
          </div>
        </div>
        <hr class="form-hr">
        <span class="form-section-label">Scope</span>
        <div style="margin-bottom:16px;">
          <label class="field-label">Data Source <span style="color:#d72225;">*</span></label>
          <select class="modal-select" id="brm-form-ds" style="width:100%;" onchange="brmUpdateCreateBtn()">
            <option value="">Select the data source</option>
            <option>Google Merchant Center</option>
            <option>Search Console</option>
            <option>Google Ads</option>
            <option>Microsoft Ads / Bing Ads</option>
            <option>Feed Analyzer</option>
          </select>
        </div>
        <div style="margin-bottom:24px;">
          <label class="field-label">Entity <span style="color:#d72225;">*</span></label>
          <select class="modal-select" id="brm-form-entity" style="width:100%;" onchange="brmUpdateCreateBtn()">
            <option value="">Select the entity</option>
            <option>Product</option>
            <option>Page</option>
            <option>URL</option>
            <option>Campaign</option>
            <option>Ad Group</option>
            <option>All Ad Groups</option>
            <option>Selected Ad Groups</option>
          </select>
        </div>
        <hr class="form-hr" style="margin-top:0;">
        <div style="display:flex;gap:10px;align-items:center;padding-top:4px;">
          <button class="btn-primary-sm pm-btn-disabled" id="brm-create-btn" disabled onclick="brmSubmitCreate()">Create Rule</button>
          <button class="btn-outline" onclick="brmShowListView()">Cancel</button>
        </div>
      </div>
    </div>
  </div><!-- /brm-create-view -->

  <!-- DETAIL VIEW -->
  <div id="brm-detail-view" style="display:none;">
    <div class="page-title-row" style="margin-bottom:4px;align-items:flex-start;">
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <h1 class="page-h1" id="brm-detail-heading">Rule</h1>
        <span id="brm-detail-impact-badge"></span>
      </div>
      <div id="brm-detail-view-btns" style="display:flex;gap:8px;align-items:center;">
        <button class="btn-outline" style="display:flex;align-items:center;gap:6px;" onclick="brmEnableEdit()">
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
          Edit
        </button>
        <button style="background:#fff0f0;color:#d72225;border:1px solid #d72225;border-radius:8px;padding:7px 14px;font-size:13px;font-family:'DM Sans',sans-serif;cursor:pointer;display:flex;align-items:center;gap:6px;" onclick="brmConfirmDelete(_brmActiveId)">
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 3.5h10M5 3.5V2.5h4v1M5.5 6v4M8.5 6v4M3 3.5l.7 8h6.6l.7-8" stroke="#d72225" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Delete
        </button>
      </div>
      <div id="brm-detail-edit-btns" style="display:none;gap:8px;align-items:center;">
        <button class="btn-primary-sm" onclick="brmSaveEdit()">Save Changes</button>
        <button class="btn-outline" onclick="brmCancelEdit()">Cancel</button>
      </div>
    </div>
    <nav class="breadcrumb" style="margin-bottom:8px;">
      <span class="bc-item bc-muted">Tools</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item bc-muted" style="cursor:pointer;" onclick="brmShowListView()">Business Rule Manager</span>
      <span class="bc-muted" style="margin:0 4px;">›</span>
      <span class="bc-item" id="brm-detail-bc" style="color:var(--color-text-primary);">Detail</span>
    </nav>
    <p id="brm-detail-modified" style="font-size:12px;color:var(--color-text-caption);margin-bottom:24px;"></p>
    <div style="max-width:649px;">
      <div class="table-card" style="padding:24px 28px;">
        <span class="form-section-label" style="margin-top:0;">Rule Details</span>
        <div style="margin-bottom:16px;">
          <label class="field-label">Rule Name</label>
          <input type="text" class="modal-input" id="brm-det-name" style="width:100%;box-sizing:border-box;" disabled>
        </div>
        <div style="margin-bottom:16px;">
          <label class="field-label">Rule Description</label>
          <textarea class="modal-textarea" id="brm-det-desc" rows="3" style="width:100%;box-sizing:border-box;resize:vertical;min-height:88px;" disabled></textarea>
        </div>
        <div style="margin-bottom:16px;">
          <label class="field-label">Severity</label>
          <div id="brm-det-severity-display" style="margin-top:4px;"></div>
          <select class="modal-select" id="brm-det-severity" style="width:160px;display:none;" disabled>
            <option>High</option><option>Medium</option><option>Low</option>
          </select>
        </div>
        <hr class="form-hr">
        <span class="form-section-label">Scope</span>
        <div style="margin-bottom:16px;">
          <label class="field-label">Data Source</label>
          <input type="text" class="modal-input" id="brm-det-ds" style="width:100%;box-sizing:border-box;" disabled>
        </div>
        <div>
          <label class="field-label">Entity</label>
          <input type="text" class="modal-input" id="brm-det-entity" style="width:100%;box-sizing:border-box;" disabled>
        </div>
      </div>
    </div>
  </div><!-- /brm-detail-view -->

</div><!-- /brm-page -->

<!-- ═══════════════════════════════════════════
     OVERVIEW PAGE (SEM / SEO)
═══════════════════════════════════════════ -->
<div id="overview-page" style="display:none; padding:32px 32px 64px;">

  <!-- Header -->
  <div class="page-title-row" style="margin-bottom:4px;">
