  <!-- ══ TRANSFORMERS TAB ══ -->
  <div class="tab-panel" id="db-tab-transformers">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:14px;">
      <div>
        <h3 style="font-family:'Instrument Sans',sans-serif;font-size:18px;font-weight:600;margin:0 0 4px;">Transformers</h3>
        <p style="font-size:13px;color:var(--color-text-caption);margin:0;">Create rules to transform your product data</p>
      </div>
      <div style="display:flex;gap:8px;">
        <button class="btn-outline" style="height:36px;padding:0 14px;font-size:13px;" onclick="openFieldExecOrderModal()">Field Execution Order</button>
        <button class="btn-primary-sm" onclick="openAddTransformerModal()">+ Add Transformer</button>
      </div>
    </div>
    <!-- filter row -->
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:8px;position:relative;">
        <span style="font-size:13px;color:var(--color-text-caption);">Filter by field:</span>
        <button class="btn-filter" id="tf-filter-btn" onclick="toggleTfFilterPanel()">
          <span id="tf-filter-label">All Fields</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="custom-dd-panel" id="tf-filter-panel" style="top:calc(100% + 4px);left:100px;min-width:180px;">
          <div class="custom-dd-item active" onclick="filterTransformerByField('')">All Fields</div>
          <div class="custom-dd-item" onclick="filterTransformerByField('description')">description</div>
          <div class="custom-dd-item" onclick="filterTransformerByField('title')">title</div>
          <div class="custom-dd-item" onclick="filterTransformerByField('brand')">brand</div>
          <div class="custom-dd-item" onclick="filterTransformerByField('salePriceEffectiveDate')">salePriceEffectiveDate</div>
          <div class="custom-dd-item" onclick="filterTransformerByField('product_type')">product_type</div>
        </div>
      </div>
      <span style="font-size:13px;color:var(--color-text-caption);margin-left:auto;" id="tf-count">7 transformers · 5 active</span>
    </div>
    <div class="table-card" style="padding:0;overflow:hidden;">
      <div class="table-scroll">
        <table class="feed-table" id="tf-table">
          <colgroup><col style="width:70px;"><col style="width:auto;"><col style="width:auto;"><col style="width:110px;"><col style="width:90px;"><col style="width:80px;"></colgroup>
          <thead><tr>
            <th>Status</th>
            <th>Condition (IF)</th>
            <th>Action (THEN)</th>
            <th>Exports</th>
            <th>Reorder</th>
            <th>Actions</th>
          </tr></thead>
          <tbody id="tf-tbody">
            <tr data-if="description"><td><label class="toggle-switch"><input type="checkbox" checked onchange="toggleTransformerRow(this)"><span class="toggle-slider"></span></label></td><td><span class="chip-if">IF</span><span class="chip-field">[description]</span> <span style="font-size:13px;color:var(--color-text-caption);">contains</span> <span class="chip-value">"Tandem"</span></td><td><span class="chip-then">THEN</span><span style="font-size:13px;color:var(--color-text-caption);">set</span> <span class="chip-field">[description]</span> <span style="font-size:13px;color:var(--color-text-caption);">to</span> <span class="chip-field">[description]</span></td><td style="font-size:12px;color:var(--color-text-caption);">All Exports</td><td><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;margin-right:2px;" onclick="moveTransformerRow(this,-1)">∧</button><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;" onclick="moveTransformerRow(this,1)">∨</button></td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">Edit</div><div class="dd-item danger" onclick="this.closest('tr').remove();updateTfCount()">Delete</div></div></div></td></tr>
            <tr data-if="title"><td><label class="toggle-switch"><input type="checkbox" checked onchange="toggleTransformerRow(this)"><span class="toggle-slider"></span></label></td><td><span class="chip-if">IF</span><span class="chip-field">[title]</span> <span style="font-size:13px;color:var(--color-text-caption);">≠</span> <span class="chip-value">"al mflds"</span></td><td><span class="chip-then">THEN</span><span style="font-size:13px;color:var(--color-text-caption);">set</span> <span class="chip-field">[sale_price]</span> <span style="font-size:13px;color:var(--color-text-caption);">to</span> <span class="chip-fn">{custom_label_0}</span></td><td style="font-size:12px;color:var(--color-text-caption);">All Exports</td><td><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;margin-right:2px;" onclick="moveTransformerRow(this,-1)">∧</button><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;" onclick="moveTransformerRow(this,1)">∨</button></td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">Edit</div><div class="dd-item danger" onclick="this.closest('tr').remove();updateTfCount()">Delete</div></div></div></td></tr>
            <tr data-if="brand"><td><label class="toggle-switch"><input type="checkbox" checked onchange="toggleTransformerRow(this)"><span class="toggle-slider"></span></label></td><td><span class="chip-if">IF</span><span class="chip-field">[brand]</span> <span style="font-size:13px;color:var(--color-text-caption);">equals</span> <span class="chip-value">"Tandem"</span></td><td><span class="chip-then">THEN</span><span style="font-size:13px;color:var(--color-text-caption);">set</span> <span class="chip-field">[brand]</span> <span style="font-size:13px;color:var(--color-text-caption);">to</span> <span class="chip-value">"Tandem Sport"</span></td><td style="font-size:12px;color:var(--color-text-caption);">All Exports</td><td><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;margin-right:2px;" onclick="moveTransformerRow(this,-1)">∧</button><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;" onclick="moveTransformerRow(this,1)">∨</button></td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">Edit</div><div class="dd-item danger" onclick="this.closest('tr').remove();updateTfCount()">Delete</div></div></div></td></tr>
            <tr data-if="title" class="transformer-row--inactive"><td><label class="toggle-switch"><input type="checkbox" onchange="toggleTransformerRow(this)"><span class="toggle-slider"></span></label></td><td><span class="chip-if">IF</span><span class="chip-fn">{toLowerCase}</span> <span class="chip-field">[title]</span> <span style="font-size:13px;color:var(--color-text-caption);">are</span> <span class="chip-value">"thinking"</span></td><td><span class="chip-then">THEN</span><span style="font-size:13px;color:var(--color-text-caption);">set</span> <span class="chip-field">[brand]</span> <span style="font-size:13px;color:var(--color-text-caption);">to</span> <span class="chip-value">"Tandem Sport"</span></td><td style="font-size:12px;color:var(--color-text-caption);">All Exports</td><td><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;margin-right:2px;" onclick="moveTransformerRow(this,-1)">∧</button><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;" onclick="moveTransformerRow(this,1)">∨</button></td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">Edit</div><div class="dd-item danger" onclick="this.closest('tr').remove();updateTfCount()">Delete</div></div></div></td></tr>
            <tr data-if="salePriceEffectiveDate"><td><label class="toggle-switch"><input type="checkbox" checked onchange="toggleTransformerRow(this)"><span class="toggle-slider"></span></label></td><td><span class="chip-if">IF</span><span class="chip-field">[salePriceEffectiveDate]</span> <span style="font-size:13px;color:var(--color-text-caption);">are</span> <span class="chip-value">""</span></td><td><span class="chip-then">THEN</span><span style="font-size:13px;color:var(--color-text-caption);">set</span> <span class="chip-field">[salePriceEffectiveDate]</span> <span style="font-size:13px;color:var(--color-text-caption);">to</span> <span class="chip-value">"null_alt_check"</span></td><td style="font-size:12px;color:var(--color-text-caption);">All Exports</td><td><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;margin-right:2px;" onclick="moveTransformerRow(this,-1)">∧</button><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;" onclick="moveTransformerRow(this,1)">∨</button></td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">Edit</div><div class="dd-item danger" onclick="this.closest('tr').remove();updateTfCount()">Delete</div></div></div></td></tr>
            <tr data-if="product_type"><td><label class="toggle-switch"><input type="checkbox" checked onchange="toggleTransformerRow(this)"><span class="toggle-slider"></span></label></td><td><span class="chip-if">IF</span><span class="chip-field">[product_type]</span> <span style="font-size:13px;color:var(--color-text-caption);">contains</span> <span class="chip-value">"Training"</span></td><td><span class="chip-then">THEN</span><span style="font-size:13px;color:var(--color-text-caption);">set</span> <span class="chip-field">[condition]</span> <span style="font-size:13px;color:var(--color-text-caption);">to</span> <span class="chip-value">"new"</span></td><td style="font-size:12px;color:var(--color-text-caption);">All Exports</td><td><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;margin-right:2px;" onclick="moveTransformerRow(this,-1)">∧</button><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;" onclick="moveTransformerRow(this,1)">∨</button></td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">Edit</div><div class="dd-item danger" onclick="this.closest('tr').remove();updateTfCount()">Delete</div></div></div></td></tr>
            <tr data-if="title"><td><label class="toggle-switch"><input type="checkbox" checked onchange="toggleTransformerRow(this)"><span class="toggle-slider"></span></label></td><td><span class="chip-if">IF</span><span class="chip-field">[title]</span> <span style="font-size:13px;color:var(--color-text-caption);">contains</span> <span class="chip-value">"Volleyball"</span></td><td><span class="chip-then">THEN</span><span style="font-size:13px;color:var(--color-text-caption);">set</span> <span class="chip-field">[google_product_category]</span> <span style="font-size:13px;color:var(--color-text-caption);">to</span> <span class="chip-value">"Sporting Goods"</span></td><td style="font-size:12px;color:var(--color-text-caption);">All Exports</td><td><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;margin-right:2px;" onclick="moveTransformerRow(this,-1)">∧</button><button class="btn-outline" style="height:26px;padding:0 8px;font-size:12px;" onclick="moveTransformerRow(this,1)">∨</button></td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">Edit</div><div class="dd-item danger" onclick="this.closest('tr').remove();updateTfCount()">Delete</div></div></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div style="padding:12px 0;font-size:13px;color:var(--color-text-caption);">Showing 1 to 7 of 7 results · 10 per page</div>
  </div>

  <!-- ══ EXPORTS TAB ══ -->
  <div class="tab-panel" id="db-tab-exports">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:14px;">
      <div>
        <h3 style="font-family:'Instrument Sans',sans-serif;font-size:18px;font-weight:600;margin:0 0 4px;">Exports</h3>
        <p style="font-size:13px;color:var(--color-text-caption);margin:0;">Manage your data export destinations</p>
      </div>
      <button class="btn-primary-sm" onclick="showAddExportPage()">+ Add Export</button>
    </div>
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
      <div style="position:relative;flex:1;max-width:280px;">
        <input type="text" class="modal-input" placeholder="🔍 Search..." style="padding:7px 11px;font-size:13px;">
      </div>
      <button class="btn-outline" style="height:36px;padding:0 14px;font-size:13px;" onclick="showToast('Filters coming soon')">Filters</button>
    </div>
    <div class="table-card" style="padding:0;overflow:hidden;">
      <div class="table-scroll">
        <table class="feed-table">
          <colgroup><col style="width:70px;"><col style="width:auto;"><col style="width:180px;"><col style="width:130px;"><col style="width:200px;"><col style="width:70px;"></colgroup>
          <thead><tr><th>Status</th><th>Name</th><th>Destination</th><th>Schedule</th><th>Last Run</th><th>Actions</th></tr></thead>
          <tbody id="exports-tbody">
            <tr><td><label class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></label></td><td>Google Shopping</td><td><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#34a853;margin-right:6px;vertical-align:middle;"></span>Google Merchant Center</td><td>Every 6 hours</td><td>Feb 1, 2:00 PM UTC · <strong>14,423</strong></td><td><button class="feed-action-btn" style="font-size:16px;">⋯</button></td></tr>
            <tr><td><label class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></label></td><td>Bing Ads</td><td><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#0078d4;margin-right:6px;vertical-align:middle;"></span>Microsoft Ads</td><td>Every 6 hours</td><td>Feb 1, 2:00 PM UTC · <strong>14,423</strong></td><td><button class="feed-action-btn" style="font-size:16px;">⋯</button></td></tr>
            <tr><td><label class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></label></td><td>Facebook</td><td><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#1877f2;margin-right:6px;vertical-align:middle;"></span>Meta</td><td>Every 6 hours</td><td>Feb 1, 2:00 PM UTC · <strong>14,423</strong></td><td><button class="feed-action-btn" style="font-size:16px;">⋯</button></td></tr>
            <tr><td><label class="toggle-switch"><input type="checkbox" checked><span class="toggle-slider"></span></label></td><td>Klorija</td><td><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#6b7280;margin-right:6px;vertical-align:middle;"></span>SFTP</td><td>Every 6 hours</td><td>Feb 1, 2:00 PM UTC</td><td><button class="feed-action-btn" style="font-size:16px;">⋯</button></td></tr>
            <tr><td><label class="toggle-switch"><input type="checkbox"><span class="toggle-slider"></span></label></td><td>ShopAGain</td><td><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#ff4500;margin-right:6px;vertical-align:middle;"></span>Reddit</td><td>Every 6 hours</td><td>Feb 1, 2:00 PM UTC</td><td><button class="feed-action-btn" style="font-size:16px;">⋯</button></td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div style="padding:12px 0;font-size:13px;color:var(--color-text-caption);">Showing 1 to 5 of 5 results · 10 per page</div>
  </div>

  <!-- ══ LOGS TAB ══ -->
  <div class="tab-panel" id="db-tab-logs">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:14px;">
      <div>
        <h3 style="font-family:'Instrument Sans',sans-serif;font-size:18px;font-weight:600;margin:0 0 4px;">Logs</h3>
        <p style="font-size:13px;color:var(--color-text-caption);margin:0;">View import and export activity</p>
      </div>
      <button class="btn-outline" style="height:36px;padding:0 14px;font-size:13px;" onclick="showToast('Exporting logs...')">⬇ Export Logs</button>
    </div>
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:14px;">
      <!-- Name filter -->
      <span style="font-size:13px;color:var(--color-text-caption);">Name:</span>
      <div style="position:relative;">
        <button class="btn-filter" style="font-size:13px;padding:6px 10px;" onclick="toggleLogFilter('name')">
          <span id="lf-name-label">All</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="custom-dd-panel" id="lf-name-panel" style="min-width:200px;">
          <div class="custom-dd-item active" onclick="setLogFilter('name','','All')">All</div>
          <div class="custom-dd-item" onclick="setLogFilter('name','Google Export_Opt','Google Export_Opt')">Google Export_Opt</div>
          <div class="custom-dd-item" onclick="setLogFilter('name','Bing','Bing')">Bing</div>
          <div class="custom-dd-item" onclick="setLogFilter('name','Facebook','Facebook')">Facebook</div>
          <div class="custom-dd-item" onclick="setLogFilter('name','All Imports','All Imports')">All Imports</div>
          <div class="custom-dd-item" onclick="setLogFilter('name','Netsuite Product Feed','Netsuite Product Feed')">Netsuite Product Feed</div>
        </div>
      </div>
      <!-- Operation filter -->
      <span style="font-size:13px;color:var(--color-text-caption);">Operation:</span>
      <div style="position:relative;">
        <button class="btn-filter" style="font-size:13px;padding:6px 10px;" onclick="toggleLogFilter('op')">
          <span id="lf-op-label">All</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="custom-dd-panel" id="lf-op-panel" style="min-width:160px;">
          <div class="custom-dd-item active" onclick="setLogFilter('op','','All')">All</div>
          <div class="custom-dd-item" onclick="setLogFilter('op','Export','Export')">Export</div>
          <div class="custom-dd-item" onclick="setLogFilter('op','Import','Import')">Import</div>
          <div class="custom-dd-item" onclick="setLogFilter('op','Download','Download')">Download</div>
        </div>
      </div>
      <!-- Status filter -->
      <span style="font-size:13px;color:var(--color-text-caption);">Status:</span>
      <div style="position:relative;">
        <button class="btn-filter" style="font-size:13px;padding:6px 10px;" onclick="toggleLogFilter('status')">
          <span id="lf-status-label">All</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="custom-dd-panel" id="lf-status-panel" style="min-width:160px;">
          <div class="custom-dd-item active" onclick="setLogFilter('status','','All')">All</div>
          <div class="custom-dd-item" onclick="setLogFilter('status','Successful','Successful')">Successful</div>
          <div class="custom-dd-item" onclick="setLogFilter('status','Failed','Failed')">Failed</div>
          <div class="custom-dd-item" onclick="setLogFilter('status','Running','Running')">Running</div>
        </div>
      </div>
      <span style="font-size:13px;color:var(--color-text-caption);">From:</span>
      <input type="date" id="lf-from" class="modal-input" value="2026-01-02" style="padding:6px 9px;font-size:13px;width:auto;" onchange="filterLogs()">
      <span style="font-size:13px;color:var(--color-text-caption);">To:</span>
      <input type="date" id="lf-to" class="modal-input" value="2026-01-02" style="padding:6px 9px;font-size:13px;width:auto;" onchange="filterLogs()">
    </div>
    <div class="table-card" style="padding:0;overflow:hidden;">
      <div class="table-scroll">
        <table class="feed-table">
          <colgroup><col style="width:22%;"><col style="width:10%;"><col style="width:10%;"><col style="width:auto;"></colgroup>
          <thead><tr><th>Name</th><th>Operation</th><th>Status</th><th>Result</th></tr></thead>
          <tbody>
            <tr data-log-name="Google Export_Opt" data-log-op="Export" data-log-status="Successful" data-log-date="2026-01-02"><td><a href="#" style="color:var(--color-blue);text-decoration:none;" onclick="showToast('Opening log detail');return false;">Google Export_Opt</a></td><td>Export</td><td style="color:var(--color-text-success);font-weight:500;">Successful</td><td>Finished Exporting 26,331 Rows in 5 min 9 sec · 5:20:32 PM</td></tr>
            <tr data-log-name="Bing" data-log-op="Export" data-log-status="Successful" data-log-date="2026-01-02"><td><a href="#" style="color:var(--color-blue);text-decoration:none;" onclick="showToast('Opening log detail');return false;">Bing</a></td><td>Export</td><td style="color:var(--color-text-success);font-weight:500;">Successful</td><td>Finished Exporting 26,331 Rows in 5 min 9 sec · 5:20:32 PM</td></tr>
            <tr data-log-name="Facebook" data-log-op="Export" data-log-status="Successful" data-log-date="2026-01-02"><td><a href="#" style="color:var(--color-blue);text-decoration:none;" onclick="showToast('Opening log detail');return false;">Facebook</a></td><td>Export</td><td style="color:var(--color-text-success);font-weight:500;">Successful</td><td>Finished Exporting 26,331 Rows in 5 min 9 sec · 5:20:32 PM</td></tr>
            <tr data-log-name="All Imports" data-log-op="Import" data-log-status="Successful" data-log-date="2026-01-02" id="log-imports-row"><td><span id="log-expand-btn" onclick="toggleLogExpand()" style="cursor:pointer;color:var(--color-text-caption);font-size:11px;margin-right:4px;">∨</span><a href="#" style="color:var(--color-blue);text-decoration:none;" onclick="showToast('Opening log detail');return false;">All Imports</a></td><td>Import</td><td style="color:var(--color-text-success);font-weight:500;">Successful</td><td>Finished Importing 26,331 Rows in 5 min 9 sec · 5:20:32 PM</td></tr>
            <tr class="log-sub-row" style="display:none;"><td colspan="4"><table style="width:100%;border-collapse:collapse;"><thead><tr><th style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--color-text-caption);padding:4px 12px 4px 0;text-align:left;">Name</th><th style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--color-text-caption);padding:4px 12px 4px 0;text-align:left;">Type</th><th style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--color-text-caption);padding:4px 12px 4px 0;text-align:left;">Load</th><th style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--color-text-caption);padding:4px 0;text-align:left;">Update</th></tr></thead><tbody><tr><td style="padding:4px 12px 4px 0;">Shopify Products</td><td style="padding:4px 12px 4px 0;">Main feed</td><td style="padding:4px 12px 4px 0;">24,013</td><td style="padding:4px 0;">0</td></tr><tr><td style="padding:4px 12px 4px 0;">Inventory Levels</td><td style="padding:4px 12px 4px 0;">Join</td><td style="padding:4px 12px 4px 0;">45,465</td><td style="padding:4px 0;">33,224</td></tr><tr><td style="padding:4px 12px 4px 0;">Pricing Override</td><td style="padding:4px 12px 4px 0;">Join</td><td style="padding:4px 12px 4px 0;">3,344</td><td style="padding:4px 0;">5,675</td></tr></tbody></table></td></tr>
            <tr data-log-name="Netsuite Product Feed" data-log-op="Download" data-log-status="Successful" data-log-date="2026-01-02"><td><a href="#" style="color:var(--color-blue);text-decoration:none;" onclick="showToast('Opening log detail');return false;">Netsuite Product Feed</a></td><td>Download</td><td style="color:var(--color-text-success);font-weight:500;">Successful</td><td>Finished Downloading Import File · 5:20:32 PM</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div style="padding:12px 0;font-size:13px;color:var(--color-text-caption);">Showing 1 to 5 of 5 results · 10 per page</div>
  </div>

</div><!-- /db-overview-page -->

<!-- ══ ADD IMPORT PAGE ══ -->
<div id="add-import-page" style="display:none;">

  <div class="page-title-row">
    <div class="page-title-left">
      <h1 class="page-h1">Add Import</h1>
      <p class="page-subtitle">Select an import source for your data</p>
    </div>
  </div>

  <nav class="breadcrumb" style="margin-bottom:24px;">
    <span class="bc-item bc-muted">Tools</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showFeedDataPage()">Feed Data Tool</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showFeedDataPage()">Feed Database</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" id="add-import-db-bc" style="cursor:pointer;" onclick="hideAddImportPage();showDbOverviewPage(currentDb);">Database</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-current">Add Import</span>
  </nav>

  <!-- Step 1: Source -->
  <div style="margin-bottom:24px;">
    <p style="font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;color:var(--color-text-primary);margin-bottom:4px;">Step 1 — Select import source</p>
    <div class="source-cards-row">
      <div class="source-card" id="src-shopify" onclick="selectImportSource('Shopify')">
        <div class="source-card-check"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div class="source-card-icon" style="background:#96bf48;">SH</div>
        <div class="source-card-title">Shopify</div>
        <div class="source-card-sub">Connect to a Shopify store via API</div>
      </div>
      <div class="source-card" id="src-csv" onclick="selectImportSource('CSV')">
        <div class="source-card-check"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div class="source-card-icon" style="background:#6b7280;">CSV</div>
        <div class="source-card-title">CSV</div>
        <div class="source-card-sub">Import from a CSV file hosted on the web</div>
      </div>
      <div class="source-card" id="src-sftp" onclick="selectImportSource('SFTP')">
        <div class="source-card-check"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div class="source-card-icon" style="background:#374151;">SF</div>
        <div class="source-card-title">SFTP</div>
        <div class="source-card-sub">Import from a file on an SFTP server</div>
      </div>
    </div>
  </div>

  <!-- Step 2: Type -->
  <div style="margin-bottom:28px;">
    <p style="font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;color:var(--color-text-primary);margin-bottom:4px;">Step 2 — Select import type</p>
    <div class="type-cards-row">
      <div class="type-card" id="type-mainfeed" onclick="selectImportType('Main Feed')">
        <div class="type-card-check"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div class="type-card-title">Main Feed</div>
        <div class="type-card-sub">The primary data source for this database. It loads into your database.</div>
      </div>
      <div class="type-card" id="type-joinfeed" onclick="selectImportType('Join Feed')">
        <div class="type-card-check"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        <div class="type-card-title">Join Feed</div>
        <div class="type-card-sub">Supplements your main feed. It adds into the existing rows in your database with extra data.</div>
      </div>
    </div>
  </div>

  <div style="display:flex;align-items:center;gap:16px;">
    <button class="btn-primary-sm" id="add-import-continue-btn" disabled onclick="continueToConfigureImport()">Continue</button>
    <button class="btn-text-link grey" onclick="cancelAddImport()">Cancel</button>
  </div>

</div><!-- /add-import-page -->

<!-- ══ CONFIGURE IMPORT PAGE ══ -->
<div id="configure-import-page" style="display:none;">

  <div class="page-title-row">
    <div class="page-title-left">
      <h1 class="page-h1">Configure Import</h1>
    </div>
  </div>

  <nav class="breadcrumb" style="margin-bottom:16px;">
    <span class="bc-item bc-muted">Tools</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showFeedDataPage()">Feed Data Tool</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showFeedDataPage()">Feed Database</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" id="cfg-import-db-bc" style="cursor:pointer;" onclick="hideConfigureImportPage();showDbOverviewPage(currentDb);">Database</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="hideConfigureImportPage();showAddImportPage();">Add Import</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-current">Configure Import</span>
  </nav>

  <!-- Sub-header -->
  <div class="wizard-subheader">
    <span>Import Source:</span>
    <span class="source-badge" id="cfg-source-badge">Shopify</span>
    <span style="margin-left:8px;">Import Type:</span>
    <span class="type-badge" id="cfg-type-badge">Main Feed</span>
  </div>

  <!-- Wizard step tabs -->
  <div class="detail-tabs-bar" id="wizard-tabs-bar" style="margin-bottom:24px;">
    <button class="detail-tab active" data-wizardtab="1">General Settings</button>
    <button class="detail-tab" data-wizardtab="2">Connection Settings</button>
    <button class="detail-tab" data-wizardtab="3">Data Types</button>
    <button class="detail-tab" data-wizardtab="4">Schedule</button>
    <button class="detail-tab" data-wizardtab="5">Preprocessing</button>
  </div>

  <!-- Step 1: General Settings -->
  <div class="wizard-step active" id="wizard-step-1">
    <div style="max-width:520px;">
      <div style="margin-bottom:18px;">
        <label class="field-label">Import Name <span class="field-required">*</span></label>
        <input type="text" id="wizard-import-name" class="modal-input" placeholder="e.g. 'Shopify Products'" style="max-width:100%;">
        <div class="field-error" id="wizard-name-error">Import name is required.</div>
      </div>
      <!-- SFTP-only: Platform dropdown -->
      <div id="wizard-step1-sftp-platform" style="display:none;margin-bottom:18px;">
        <label class="field-label">Platform <span class="field-required">*</span></label>
        <select class="modal-select">
          <option selected>Shopify</option>
          <option>WooCommerce</option>
          <option>Magento</option>
          <option>BigCommerce</option>
          <option>Custom</option>
        </select>
      </div>
    </div>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="showAddImportPage();hideConfigureImportPage();">Back</button>
      <button class="btn-primary-sm" onclick="goWizardStep(2)">Next</button>
      <button class="btn-text-link grey" onclick="cancelConfigureImport()">Cancel</button>
    </div>
  </div>

  <!-- Step 2: Connection Settings -->
  <div class="wizard-step" id="wizard-step-2">
    <div style="max-width:520px;">

      <!-- Shopify fields -->
      <div id="wizard-step2-shopify">
        <div style="margin-bottom:18px;">
          <label class="field-label" style="display:flex;align-items:center;gap:6px;">
            OAuth token / App password
            <span class="tooltip-icon" title="Find this in your Shopify admin under Apps > Private apps">?</span>
          </label>
          <div class="password-input-wrap">
            <input type="password" id="wizard-oauth-token" class="modal-input" placeholder="Enter your Shopify access token">
            <button class="password-toggle" onclick="togglePasswordField('wizard-oauth-token',this)" type="button">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        <div style="margin-bottom:6px;">
          <label class="field-label">Shop name <span class="field-required">*</span></label>
          <div class="input-suffix-wrap">
            <input type="text" id="wizard-shop-name" placeholder="your-store-name">
            <span class="input-suffix-text">.myshopify.com</span>
          </div>
          <button class="btn-text-link" style="margin-top:8px;" type="button">Test Connection</button>
        </div>
      </div>

      <!-- CSV fields -->
      <div id="wizard-step2-csv" style="display:none;">
        <div style="margin-bottom:18px;">
          <label class="field-label">URL <span class="field-required">*</span></label>
          <input type="text" class="modal-input" placeholder="https://www.content.docs/yourFeed.csv">
          <div style="font-size:12px;color:var(--color-text-caption);margin-top:5px;">Import a file from a URL. Supported types: CSV, TXT</div>
        </div>
        <div style="margin-bottom:18px;">
          <div style="font-size:13px;font-weight:600;color:var(--color-text-primary);margin-bottom:4px;">URL Parameters <span style="font-weight:400;color:var(--color-text-caption);">(Optional)</span></div>
          <div style="font-size:12px;color:var(--color-text-caption);margin-bottom:10px;">Add parameters if the URL requires authentication or additional values</div>
          <table style="width:100%;border-collapse:collapse;">
            <thead>
              <tr>
                <th style="font-size:11px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;color:var(--color-text-caption);padding:0 8px 6px 0;text-align:left;">Parameter Name</th>
                <th style="font-size:11px;font-weight:700;letter-spacing:0.05em;text-transform:uppercase;color:var(--color-text-caption);padding:0 8px 6px 0;text-align:left;">Parameter Value</th>
                <th style="width:32px;"></th>
              </tr>
            </thead>
            <tbody id="csv-params-tbody">
              <tr>
                <td style="padding:0 8px 6px 0;"><input type="text" class="modal-input" placeholder="e.g. username" style="padding:6px 9px;font-size:13px;"></td>
                <td style="padding:0 8px 6px 0;"><input type="text" class="modal-input" placeholder="e.g. mypassword" style="padding:6px 9px;font-size:13px;"></td>
                <td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:16px;padding:0;">🗑</button></td>
              </tr>
            </tbody>
          </table>
          <button class="btn-text-link" style="margin-top:4px;" onclick="addCsvParam()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add parameter
          </button>
        </div>
        <div style="margin-bottom:18px;">
          <label class="field-label">User Agent <span style="font-weight:400;color:var(--color-text-caption);">(Optional)</span></label>
          <textarea class="modal-input" rows="3" placeholder="Mozilla/5.0 (X11; Linux x86_64; rv:12.0) Gecko/20100101 Firefox/12.0" style="resize:vertical;"></textarea>
          <div style="font-size:12px;color:var(--color-text-caption);margin-top:5px;">Provide a user agent if the host server requires one</div>
        </div>
      </div>

      <!-- SFTP fields -->
      <div id="wizard-step2-sftp" style="display:none;">
        <div style="margin-bottom:16px;">
          <label class="field-label">FTP Protocol <span class="field-required">*</span></label>
          <select class="modal-select">
            <option selected>SFTP</option>
            <option>FTP</option>
            <option>FTPS</option>
          </select>
        </div>
        <div style="display:flex;gap:12px;margin-bottom:16px;">
          <div style="flex:7;">
            <label class="field-label">Host <span class="field-required">*</span></label>
            <input type="text" class="modal-input" placeholder="e.g., sftp.example.com">
          </div>
          <div style="flex:3;">
            <label class="field-label">Port <span class="field-required">*</span></label>
            <input type="text" class="modal-input" placeholder="22">
          </div>
        </div>
        <div style="display:flex;gap:12px;margin-bottom:16px;">
          <div style="flex:1;">
            <label class="field-label">Username <span class="field-required">*</span></label>
            <input type="text" class="modal-input" placeholder="username">
          </div>
          <div style="flex:1;">
            <label class="field-label">Password <span class="field-required">*</span></label>
            <input type="password" class="modal-input" placeholder="••••••••">
          </div>
        </div>
        <div style="margin-bottom:16px;">
          <label class="field-label">Private Key <span style="font-weight:400;color:var(--color-text-caption);">(Optional)</span></label>
          <textarea class="modal-input" rows="3" placeholder="Paste private key here..." style="resize:vertical;"></textarea>
          <div style="font-size:12px;color:var(--color-text-caption);margin-top:5px;">Use instead of password for key-based authentication.</div>
        </div>
        <div style="margin-bottom:16px;">
          <label class="field-label">Directory <span class="field-required">*</span></label>
          <input type="text" class="modal-input" placeholder="/feeds/">
          <div style="font-size:12px;color:var(--color-text-caption);margin-top:5px;">Path to the folder containing the file</div>
        </div>
      </div>

    </div>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="goWizardStep(1)">Back</button>
      <button class="btn-primary-sm" onclick="goWizardStep(3)">Next</button>
      <button class="btn-text-link grey" onclick="cancelConfigureImport()">Cancel</button>
    </div>
  </div>

  <!-- Step 3: Data Types -->
  <div class="wizard-step" id="wizard-step-3">
    <div style="max-width:560px;">
      <div class="info-banner-blue">These operations run on the file before it's imported into the database. Adjustments you can't change at the source level are easier to make here than try to address after import.</div>
      <div class="checkbox-group">
        <div>
          <div class="checkbox-item">
            <input type="checkbox" id="dt-products" checked disabled>
            <div>
              <label class="checkbox-label" for="dt-products">Products</label>
              <div class="checkbox-sub">Core product information</div>
            </div>
          </div>
          <div class="checkbox-sub-group" id="products-sub-options">
            <div class="checkbox-item"><input type="checkbox"><label class="checkbox-label" style="font-size:13px;font-weight:400;">Include: GMC Transition ID</label></div>
            <div class="checkbox-item"><input type="checkbox"><label class="checkbox-label" style="font-size:13px;font-weight:400;">Markets</label></div>
            <div class="checkbox-item"><input type="checkbox"><label class="checkbox-label" style="font-size:13px;font-weight:400;">Presentation group</label></div>
            <div class="checkbox-item"><input type="checkbox"><label class="checkbox-label" style="font-size:13px;font-weight:400;">Contextual pricing</label></div>
            <div class="checkbox-item"><input type="checkbox"><label class="checkbox-label" style="font-size:13px;font-weight:400;">Variant names into individual columns</label></div>
            <div class="checkbox-item"><input type="checkbox"><label class="checkbox-label" style="font-size:13px;font-weight:400;">Extra parent fields</label></div>
            <div class="checkbox-item"><input type="checkbox"><label class="checkbox-label" style="font-size:13px;font-weight:400;">Tax rate <span class="checkbox-sub">(Optional as cost)</span></label></div>
          </div>
        </div>
        <div class="checkbox-item"><input type="checkbox"><div><label class="checkbox-label">Collections</label><div class="checkbox-sub">Product collections/categories</div></div></div>
        <div class="checkbox-item"><input type="checkbox"><div><label class="checkbox-label">Inventory Item</label><div class="checkbox-sub">Inventory data (cost, country of origin)</div></div></div>
        <div class="checkbox-item"><input type="checkbox"><div><label class="checkbox-label">Inventory Levels</label><div class="checkbox-sub">Stock quantities</div></div></div>
        <div class="checkbox-item"><input type="checkbox"><div><label class="checkbox-label">Metafields</label><div class="checkbox-sub">Shop-level metadata</div></div></div>
      </div>
      <div class="info-banner-warn" style="margin-top:16px;">Every additional data type may increase import run time.</div>
    </div>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="goWizardStep(2)">Back</button>
      <button class="btn-primary-sm" onclick="goWizardStep(4)">Next</button>
      <button class="btn-text-link grey" onclick="cancelConfigureImport()">Cancel</button>
    </div>
  </div>

  <!-- Step 4: Schedule -->
  <div class="wizard-step" id="wizard-step-4">
    <div style="max-width:520px;">
      <div style="margin-bottom:18px;">
        <label class="field-label">Frequency <span class="field-required">*</span></label>
        <select id="wizard-frequency" class="modal-select" onchange="handleFrequencyChange(this.value)">
          <option value="">Select the import schedule</option>
          <option value="weekdays">Weekdays (Mon–Fri)</option>
          <option value="weekends">Weekends (Sat–Sun)</option>
          <option value="custom">Custom</option>
        </select>
      </div>
      <div id="custom-schedule-fields" style="display:none;">
        <div style="margin-bottom:14px;">
          <label class="field-label">Day</label>
          <select class="modal-select">
            <option value="">Select the import days</option>
            <option>Monday</option><option>Tuesday</option><option>Wednesday</option>
            <option>Thursday</option><option>Friday</option><option>Saturday</option><option>Sunday</option>
          </select>
        </div>
        <div style="margin-bottom:14px;">
          <label class="field-label">Time</label>
          <select class="modal-select">
            <option value="">Select the import times</option>
            <option>12:00 AM</option><option>6:00 AM</option><option>9:00 AM</option>
            <option>12:00 PM</option><option>3:00 PM</option><option>6:00 PM</option><option>9:00 PM</option>
          </select>
        </div>
        <div style="margin-bottom:14px;">
          <label class="field-label">Timezone</label>
          <select class="modal-select">
            <option selected>New York City, United States (EST, UTC -05:00)</option>
            <option>Los Angeles, United States (PST, UTC -08:00)</option>
            <option>Chicago, United States (CST, UTC -06:00)</option>
            <option>London, United Kingdom (GMT, UTC +00:00)</option>
            <option>Berlin, Germany (CET, UTC +01:00)</option>
          </select>
        </div>
      </div>
    </div>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="goWizardStep(3)">Back</button>
      <button class="btn-primary-sm" onclick="goWizardStep(5)">Next</button>
      <button class="btn-text-link grey" onclick="cancelConfigureImport()">Cancel</button>
    </div>
  </div>

  <!-- Step 5: Preprocessing -->
  <div class="wizard-step" id="wizard-step-5">
    <div style="max-width:600px;">
      <div class="info-banner-warn">These operations run on the file before it's imported into the database. Unlike when the source file is imported, adjustments you can't change at the source level are easier to make here than try to address after import.</div>

      <!-- Product Filters -->
      <div class="section-block" style="border-top:none;margin-top:0;padding-top:0;">
        <div class="section-block-title">Product Filters</div>
        <div class="section-block-sub">Only import products that match these conditions.</div>
        <div class="filter-table-wrap">
          <table class="filter-table">
            <tbody id="filter-rows-tbody">
              <tr>
                <td style="color:var(--color-text-caption);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;padding-bottom:6px;">Filter</td>
                <td style="color:var(--color-text-caption);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;padding-bottom:6px;">Value</td>
                <td style="width:36px;"></td>
              </tr>
              <tr>
                <td><select class="modal-select" style="padding:8px 11px;font-size:14px;"><option selected>Published Status</option></select></td>
                <td><select class="modal-select" style="padding:8px 11px;font-size:14px;"><option selected>Published Products</option></select></td>
                <td><button class="btn-danger-icon" onclick="removeFilterRow(this)" title="Remove filter"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg></button></td>
              </tr>
            </tbody>
          </table>
        </div>
        <button class="btn-text-link" onclick="addFilterRow()" style="margin-top:4px;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Filter
        </button>
      </div>

      <!-- File Actions — CSV only -->
      <div id="wizard-step5-file-actions" style="display:none;">
        <div class="section-block">
          <div class="section-block-title">File Actions</div>
          <div class="section-block-sub">Operations to run on the file before import.</div>
          <select class="modal-select" style="margin-top:8px;max-width:300px;">
            <option>Remove BOM</option>
            <option>Strip quotes</option>
            <option>Normalize line endings</option>
            <option>Remove empty rows</option>
          </select>
          <br>
          <button class="btn-text-link" style="margin-top:8px;" onclick="showToast('Add header coming soon')">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add header
          </button>
        </div>
      </div>

    </div>
    <div class="wizard-btn-row">
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="goWizardStep(4)">Back</button>
      <button class="btn-primary-sm" style="padding:0 20px;" onclick="submitImport()">Save &amp; Import</button>
      <button class="btn-text-link grey" onclick="cancelConfigureImport()">Cancel</button>
    </div>
  </div>

</div><!-- /configure-import-page -->

<!-- ══ FIELD MAPPING PAGE ══ -->
<div id="field-mapping-page" style="display:none;">
  <div class="page-title-row">
    <div class="page-title-left">
      <h1 class="page-h1">Field Mapping</h1>
      <p class="page-subtitle" style="text-align:left;">Map source fields to the database fields</p>
    </div>
    <div style="display:flex;align-items:center;gap:10px;">
      <span style="background:#e8f5e2;color:#3a7d0a;border-radius:20px;padding:3px 10px;font-size:12px;font-weight:500;">Shopify</span>
      <button class="btn-text-link" style="font-size:13px;" onclick="showToast('Parse settings coming soon')">⚙ Parse Settings</button>
    </div>
  </div>
  <nav class="breadcrumb" style="margin-bottom:12px;">
    <span class="bc-item bc-muted">Tools</span><span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showFeedDataPage()">Feed Data Tool</span><span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showDbOverviewPage()">Feed Database</span><span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showDbOverviewPage();switchDbTab('imports')">Imports</span><span class="bc-item bc-muted">›</span>
    <span class="bc-item">Field Mapping</span>
  </nav>
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
    <span style="font-size:14px;font-weight:600;color:var(--color-text-primary);">45/48 fields mapped</span>
    <button class="btn-text-link" style="font-size:13px;" onclick="showToast('Unmapped fields coming soon')">View unmapped ∨</button>
  </div>
  <div class="table-card" style="padding:0;overflow:hidden;">
    <div class="table-scroll">
      <table class="feed-table">
        <colgroup><col style="width:35%;"><col style="width:28%;"><col style="width:28%;"><col style="width:9%;"></colgroup>
        <thead><tr>
          <th>Internal Fields</th>
          <th>Source Fields <span style="font-size:11px;cursor:help;" title="The field name from the source data">ⓘ</span></th>
          <th>Value</th>
          <th></th>
        </tr></thead>
        <tbody id="field-mapping-tbody">
          <tr><td><div style="display:flex;align-items:center;gap:4px;"><span style="color:#ef4444;font-weight:600;font-size:12px;">*</span><div class="autocomplete-wrapper" style="flex:1;"><input type="text" class="autocomplete-input modal-input" value="id" style="padding:5px 8px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></div></td><td style="font-size:13px;">product_id</td><td style="font-size:13px;color:var(--color-text-caption);">47728851222814</td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
          <tr><td><div style="display:flex;align-items:center;gap:4px;"><span style="color:#ef4444;font-weight:600;font-size:12px;">*</span><div class="autocomplete-wrapper" style="flex:1;"><input type="text" class="autocomplete-input modal-input" value="title" style="padding:5px 8px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></div></td><td style="font-size:13px;">product_title</td><td style="font-size:13px;color:var(--color-text-caption);">9005505052958</td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
          <tr><td><div style="display:flex;align-items:center;gap:4px;"><span style="color:#ef4444;font-weight:600;font-size:12px;">*</span><div class="autocomplete-wrapper" style="flex:1;"><input type="text" class="autocomplete-input modal-input" value="cost" style="padding:5px 8px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></div></td><td style="font-size:13px;">price</td><td style="font-size:13px;color:var(--color-text-caption);">49.95</td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
          <tr><td><div style="display:flex;align-items:center;gap:4px;"><span style="color:#ef4444;font-weight:600;font-size:12px;">*</span><div class="autocomplete-wrapper" style="flex:1;"><input type="text" class="autocomplete-input modal-input" value="availability" style="padding:5px 8px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></div></td><td style="font-size:13px;">stock_status</td><td style="font-size:13px;color:var(--color-text-caption);">out of stock</td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
          <tr><td><div style="display:flex;align-items:center;gap:4px;"><span style="color:#ef4444;font-weight:600;font-size:12px;">*</span><div class="autocomplete-wrapper" style="flex:1;"><input type="text" class="autocomplete-input modal-input" value="link" style="padding:5px 8px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></div></td><td style="font-size:13px;">product_link</td><td style="font-size:13px;color:var(--color-text-caption);">https://www.allvolleyball.com/...</td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
          <tr><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="brand" style="padding:5px 8px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td style="font-size:13px;">manufacturer</td><td style="font-size:13px;color:var(--color-text-caption);">Wilson Team Sports</td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
          <tr><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="description" style="padding:5px 8px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td style="font-size:13px;">body_html</td><td style="font-size:13px;color:var(--color-text-caption);">Volleyball Bags and Backpacks...</td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
          <tr><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="image_link" style="padding:5px 8px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td style="font-size:13px;">featured_image</td><td style="font-size:13px;color:var(--color-text-caption);">https://cdn.shopify.com/...</td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
          <tr><td><div class="autocomplete-wrapper"><input type="text" class="autocomplete-input modal-input" value="google_product_category" style="padding:5px 8px;font-size:13px;" autocomplete="off"><ul class="autocomplete-dropdown"></ul></div></td><td style="font-size:13px;">product_category</td><td style="font-size:13px;color:var(--color-text-caption);">Sporting Goods &gt; Team Sports</td><td><button onclick="this.closest('tr').remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:14px;padding:0;">🗑</button></td></tr>
        </tbody>
      </table>
    </div>
  </div>
  <div style="display:flex;align-items:center;justify-content:space-between;margin-top:16px;flex-wrap:wrap;gap:10px;">
    <button class="btn-text-link" onclick="showToast('Field mapping row added')">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Field Mapping
    </button>
    <div style="display:flex;gap:8px;">
      <button class="btn-primary-sm" onclick="showToast('Field mapping saved')">💾 Save field mapping</button>
      <button class="btn-outline" style="height:36px;padding:0 14px;font-size:13px;" onclick="showDbOverviewPage();switchDbTab('transformers')">Go to Transformers</button>
    </div>
  </div>
</div><!-- /field-mapping-page -->

<!-- ══ ROW DETAIL PAGE ══ -->
<div id="row-detail-page" style="display:none;">
  <div class="page-title-row">
    <div class="page-title-left">
      <h1 class="page-h1" id="row-detail-title">Molten MVB Set Suitcase</h1>
    </div>
  </div>
  <nav class="breadcrumb" style="margin-bottom:16px;">
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="hideRowDetailPage();switchDbTab('dataview');">← Back to Data View</span>
  </nav>
  <div class="detail-tabs-bar" id="row-detail-tabs-bar" style="margin-bottom:20px;">
    <button class="detail-tab active" onclick="showToast('Raw Data view active')">Raw Data</button>
    <button class="detail-tab" onclick="showToast('Transformed Data view active')">Transformed Data</button>
  </div>
  <div class="table-card" style="padding:0;overflow:hidden;">
    <div class="table-scroll">
      <table class="feed-table">
        <colgroup><col style="width:22%;"><col style="width:39%;"><col style="width:39%;"></colgroup>
        <thead><tr><th>Field</th><th>Transformed Data</th><th>Raw Data</th></tr></thead>
        <tbody id="row-detail-tbody">
          <tr><td>image_link</td><td>https://d2.amazonaws.com/shops/...</td><td>https://d2.amazonaws.com/shops/...</td></tr>
          <tr><td>id</td><td>MVBSUT</td><td>MVBSUT</td></tr>
          <tr><td>title</td><td class="field-changed">Molten MVB Set Suitcase</td><td>Molten MVB Ball Suitcase</td></tr>
          <tr><td>product_type</td><td class="field-changed">Equipment &gt; Bags and Backpacks &gt; molten-mvb-ball-suitc...</td><td>Equipment &gt; Bags and Backpacks &gt; molten-mvb-ball-suitcase &gt; ...</td></tr>
          <tr><td>google_product_category</td><td class="field-changed">Sporting Goods &gt; Team Sports &gt; Indoor Volleyball &gt; Volleyball...</td><td>Sporting Goods &gt; Team Sports &gt; Indoor Volleyball bag</td></tr>
          <tr><td>description</td><td>Volleyball Bags and Backpacks. Rectangular nylon ball bag...</td><td>Volleyball Bags and Backpacks. Rectangular nylon ball bag...</td></tr>
          <tr><td>link</td><td>https://www.allvolleyball.com/products/...</td><td>https://www.allvolleyball.com/products/...</td></tr>
          <tr><td>additional_image_link_opt</td><td style="color:var(--color-text-caption);">(empty)</td><td style="color:var(--color-text-caption);">(empty)</td></tr>
