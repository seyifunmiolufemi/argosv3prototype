<!-- ══════════════════════════════════════════════════════ -->
<!-- SCREEN 10: DASHBOARD                                    -->
<!-- ══════════════════════════════════════════════════════ -->
<div class="screen" id="screen-dashboard">
<div id="app-shell">

  <!-- ════════════ SIDEBAR ════════════ -->
  <aside id="sidebar">
    <div class="sb-top">

      <!-- Logo row -->
      <div class="sb-header">
        <div class="sb-logo-group">
          <img src="data:image/svg+xml;base64," class="sb-logo-img" alt="StatBid" />
          <span class="sb-wordmark">StatBid</span>
        </div>
        <button class="sb-toggle-btn" id="sb-toggle" title="Collapse sidebar">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <rect x="0.7" y="0.7" width="12.6" height="12.6" rx="1.8" stroke="#58657d" stroke-width="1.3"/>
            <rect x="0.7" y="0.7" width="4.6" height="12.6" rx="1.8" fill="#e0e3ea" stroke="#58657d" stroke-width="1.3"/>
            <path d="M3 5.2L1.6 7L3 8.8" stroke="#58657d" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <!-- Nav -->
      <nav class="sb-nav">

        <div class="sb-group" id="grp-usermgmt">
          <div class="sb-group-hdr" data-grp="usermgmt">
            <div class="sb-hdr-left">
              <svg class="sb-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span class="sb-lbl">User Management</span>
            </div>
            <svg class="sb-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          <div class="sb-kids" id="kids-usermgmt">
            <div class="sb-kid" data-nav="permission-manager"><div class="sb-kid-bar"></div><span>Permission Manager</span></div>
          </div>
        </div>

        <div class="sb-group" id="grp-clientmgmt">
          <div class="sb-group-hdr" data-grp="clientmgmt">
            <div class="sb-hdr-left">
              <svg class="sb-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              <span class="sb-lbl">Client Management</span>
            </div>
            <svg class="sb-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          <div class="sb-kids" id="kids-clientmgmt">
            <div class="sb-kid" data-nav="clients"><div class="sb-kid-bar"></div><span>Clients</span></div>
          </div>
        </div>

        <div class="sb-group sb-group-open" id="grp-tools">
          <div class="sb-group-hdr sb-hdr-active" data-grp="tools">
            <div class="sb-hdr-left">
              <svg class="sb-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              <span class="sb-lbl">Tools</span>
            </div>
            <svg class="sb-chev sb-chev-open" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          <div class="sb-kids sb-kids-open" id="kids-tools">
            <div class="sb-kid sb-kid-active" data-nav="issue-center"><div class="sb-kid-bar"></div><span>Issue Center</span></div>
            <div class="sb-kid" data-nav="page-level"><div class="sb-kid-bar"></div><span>Page Level View</span></div>
            <div class="sb-kid" data-nav="search-term"><div class="sb-kid-bar"></div><span>Search Term Grader</span></div>
            <div class="sb-kid" data-nav="test-designer"><div class="sb-kid-bar"></div><span>Test Designer</span></div>
            <div class="sb-kid" data-nav="feed-quality"><div class="sb-kid-bar"></div><span>Feed Quality Check</span></div>
            <div class="sb-kid" data-nav="alerts"><div class="sb-kid-bar"></div><span>Alerts Management</span></div>
            <div class="sb-kid" data-nav="annotations"><div class="sb-kid-bar"></div><span>Annotations</span></div>
            <div class="sb-kid" data-nav="biz-rules"><div class="sb-kid-bar"></div><span>Business Rule Manager</span></div>
            <div class="sb-kid" data-nav="feed-data"><div class="sb-kid-bar"></div><span>Feed Data Tool</span></div>
          </div>
        </div>

        <div class="sb-group" id="grp-reports">
          <div class="sb-group-hdr" data-grp="reports">
            <div class="sb-hdr-left">
              <svg class="sb-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              <span class="sb-lbl">Reports</span>
            </div>
            <svg class="sb-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          <div class="sb-kids" id="kids-reports">
            <div class="sb-kid" data-nav="sem-overview"><div class="sb-kid-bar"></div><span>Overview</span></div>
            <div class="sb-kid" data-nav="highlights-table"><div class="sb-kid-bar"></div>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="1" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.3"/><rect x="9" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.3"/><rect x="1" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.3"/><rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.3"/></svg>
              <span>Highlights Table</span>
            </div>
          </div>
        </div>

        <div class="sb-group" id="grp-monitoring">
          <div class="sb-group-hdr" data-grp="monitoring">
            <div class="sb-hdr-left">
              <svg class="sb-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              <span class="sb-lbl">Monitoring</span>
            </div>
            <svg class="sb-chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          <div class="sb-kids" id="kids-monitoring">
            <div class="sb-kid" data-nav="event-log"><div class="sb-kid-bar"></div><span>Event Log</span></div>
            <div class="sb-kid" data-nav="session-monitor"><div class="sb-kid-bar"></div><span>Session Monitor</span></div>
            <div class="sb-kid" data-nav="portfolio"><div class="sb-kid-bar"></div><span>Portfolio Performance</span></div>
          </div>
        </div>

        <!-- Settings -->
        <div class="sb-group" id="grp-settings">
          <div class="sb-group-hdr" data-grp="settings">
            <div class="sb-hdr-left">
              <svg class="sb-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              <span class="sb-lbl">Settings</span>
            </div>
            <svg class="sb-chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          <div class="sb-kids" id="kids-settings">
            <div class="sb-kid" data-nav="integrations">
              <div class="sb-kid-bar"></div>
              Integrations
            </div>
          </div>
        </div>

      </nav>
    </div>

    <!-- Sidebar bottom -->
    <div class="sb-bottom">
      <div class="sb-btm-item" id="sb-docs-btn">
        <svg class="sb-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        <span class="sb-lbl">Documentation</span>
      </div>
      <div class="sb-btm-item" id="sb-dark-btn">
        <svg class="sb-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <span class="sb-lbl" id="dark-mode-label">Enable Dark Mode</span>
      </div>
    </div>
  </aside>

  <!-- ════════════ MAIN ════════════ -->
  <main id="sb-main">

    <!-- Page content -->
    <div id="page-content">

      <!-- ══ LIST VIEW ══ -->
      <div id="ic-list">

        <!-- Page title row -->
        <div class="page-title-row">
          <div class="page-title-left">
            <div class="page-title-heading">
              <h1 class="page-h1">Issue Center</h1>
              <span class="count-badge" id="issue-count-badge">20 issues</span>
            </div>
            <p class="page-subtitle">Detected issues from StatBid's business rules</p>
          </div>
          <div class="page-title-right">
            <div class="dd-trigger-wrap" id="date-wrap">
              <button class="btn-outline" id="date-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span id="date-label">Last 30 Days</span>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              <div class="dropdown-menu" id="date-menu" data-dd="date-wrap">
                <div class="dd-item dd-active" data-val="Last 30 Days" data-dd-target="date-label">Last 30 Days</div>
                <div class="dd-item" data-val="Last 7 Days" data-dd-target="date-label">Last 7 Days</div>
                <div class="dd-item" data-val="Last 14 Days" data-dd-target="date-label">Last 14 Days</div>
                <div class="dd-item" data-val="Last 60 Days" data-dd-target="date-label">Last 60 Days</div>
                <div class="dd-item" data-val="Last 90 Days" data-dd-target="date-label">Last 90 Days</div>
                <div class="dd-item" data-val="This Month" data-dd-target="date-label">This Month</div>
                <div class="dd-item" data-val="Last Month" data-dd-target="date-label">Last Month</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Breadcrumb -->
        <nav class="breadcrumb">
          <span class="bc-item bc-muted">Tools</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#bbc0c8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span class="bc-item bc-current">Issue Center</span>
        </nav>

        <!-- Tier 1 filters: Client + Website -->
        <div class="filter-row filter-row-top">
          <div class="dd-trigger-wrap filter-dd-wrap" id="client-wrap">
            <button class="btn-outline filter-btn" id="client-btn">
              <span id="client-label">Client: All</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="dropdown-menu dropdown-scroll" id="client-menu" data-dd="client-wrap"></div>
          </div>
          <div class="dd-trigger-wrap filter-dd-wrap" id="website-wrap">
            <button class="btn-outline filter-btn" id="website-btn">
              <span id="website-label">Website: All</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="dropdown-menu dropdown-scroll" id="website-menu" data-dd="website-wrap"></div>
          </div>
        </div>

        <!-- Tier 2 filters: Search + Severity + Status -->
        <div class="filter-row filter-row-bottom">
          <div class="search-box">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#737c8c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="text" id="issue-search" placeholder="Search issues, clients…" />
          </div>
          <div class="dd-trigger-wrap" id="sev-wrap">
            <button class="btn-outline filter-btn-sm" id="sev-btn">
              <span id="sev-label">Severity: All</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="dropdown-menu" id="sev-menu" data-dd="sev-wrap" style="min-width:210px;">
              <div class="dd-item dd-active" data-filter="sev" data-val="">All Severities</div>
              <div class="dd-item" data-filter="sev" data-val="action-required">Action Required</div>
              <div class="dd-item" data-filter="sev" data-val="review-recommended">Review Recommended</div>
              <div class="dd-item" data-filter="sev" data-val="information">Information</div>
            </div>
          </div>
          <div class="dd-trigger-wrap" id="status-wrap">
            <button class="btn-outline filter-btn-sm" id="status-btn">
              <span id="status-label">Status: All</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="dropdown-menu" id="status-menu" data-dd="status-wrap" style="min-width:190px;">
              <div class="dd-item dd-active" data-filter="status" data-val="">All Statuses</div>
              <div class="dd-item" data-filter="status" data-val="needs-review">Needs Review</div>
              <div class="dd-item" data-filter="status" data-val="in-progress">In Progress</div>
              <div class="dd-item" data-filter="status" data-val="resolved">Resolved</div>
            </div>
          </div>
        </div>

        <!-- Table -->
        <div class="table-card">
          <div class="table-scroll">
            <table id="issues-table">
              <colgroup>
                <col class="col-issue">
                <col class="col-sev">
                <col class="col-status">
                <col class="col-date">
                <col class="col-mod">
                <col class="col-action">
              </colgroup>
              <thead>
                <tr>
                  <th class="th-issue">ISSUE</th>
                  <th>SEVERITY</th>
                  <th>STATUS</th>
                  <th>DATE DISCOVERED</th>
                  <th>LAST MODIFIED</th>
                  <th>ACTION</th>
                </tr>
              </thead>
              <tbody id="issues-tbody"></tbody>
            </table>
          </div>
        </div>

        <!-- Empty state (hidden by default) -->
        <div class="empty-state" id="table-empty" style="display:none;">
          <div class="empty-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#346ed9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <p class="empty-title">No issues found</p>
          <p class="empty-sub">Try adjusting your filters or search query</p>
        </div>

      </div><!-- /ic-list -->

      <!-- ══ DETAIL VIEW ══ -->
      <div id="ic-detail" style="display:none;">

        <!-- Detail header -->
        <div class="detail-title-row">
          <div class="detail-title-left">
            <div class="detail-title-heading">
              <h1 class="page-h1" id="detail-title">Issue Title</h1>
              <span id="detail-severity-badge"></span>
            </div>
            <p class="page-subtitle">Detected issues from StatBid's business rules</p>
          </div>
          <div class="detail-title-right">
            <div class="dd-trigger-wrap" id="set-status-wrap">
              <button class="btn-outline" id="set-status-btn">
                <span id="current-status-display">Set Status</span>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              <div class="dropdown-menu" id="set-status-menu" data-dd="set-status-wrap" style="min-width:260px;">
                <div class="dd-section-label">Set Status</div>
                <div class="dd-item status-option" data-status="needs-review">
                  <span class="status-dot" style="background:#8c781b;"></span>
                  <div><div class="status-opt-label">Needs Review</div><div class="status-opt-desc">Issue detected, awaiting action</div></div>
                </div>
                <div class="dd-item status-option" data-status="in-progress">
                  <span class="status-dot" style="background:#346ed9;"></span>
                  <div><div class="status-opt-label">In Progress</div><div class="status-opt-desc">Fix applied, awaiting verification</div></div>
                </div>
                <div class="dd-item status-option" data-status="resolved">
                  <span class="status-dot" style="background:#289253;"></span>
                  <div><div class="status-opt-label">Resolved</div><div class="status-opt-desc">Issue confirmed as fixed</div></div>
                </div>
              </div>
            </div>
            <button class="btn-success" id="mark-resolved-btn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              Mark as Resolved
            </button>
          </div>
        </div>

        <!-- Detail breadcrumb -->
        <nav class="breadcrumb">
          <span class="bc-item bc-link" id="bc-back">Tools</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#bbc0c8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span class="bc-item bc-link" id="bc-back2">Issue Center</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#bbc0c8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span class="bc-item bc-current" id="detail-crumb-title"></span>
        </nav>

        <!-- Meta strip -->
        <div class="detail-meta-strip">
          <div class="meta-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            <span>Client: <strong id="meta-client"></strong></span>
          </div>
          <div class="meta-sep"></div>
          <div class="meta-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span>Website: <strong id="meta-website"></strong></span>
          </div>
          <div class="meta-sep"></div>
          <div class="meta-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            <span>Data Source: <strong>Google Ads API</strong></span>
          </div>
          <div class="meta-sep"></div>
          <div class="meta-item">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>Discovered: <strong id="meta-date"></strong></span>
          </div>
        </div>

        <!-- Description -->
        <p class="detail-desc" id="detail-desc"></p>

        <!-- Tabs -->
        <div class="detail-tabs-bar">
          <button class="detail-tab active" data-tab="detection">Detection Summary</button>
          <button class="detail-tab" data-tab="affected">Affected Items</button>
          <button class="detail-tab" data-tab="impact">Impact Analysis</button>
          <button class="detail-tab" data-tab="resolution">Resolution</button>
          <button class="detail-tab" data-tab="activity">Activity Log</button>
        </div>

        <!-- Tab panels -->
        <div id="tab-detection" class="tab-panel active">
          <div class="info-card">
            <div class="info-card-title">Detection Summary</div>
            <div class="info-card-subtitle">What was found and why this issue was triggered</div>
            <p class="info-card-body" id="detection-body"></p>
          </div>
        </div>

        <div id="tab-affected" class="tab-panel">
          <div class="table-card" style="margin-top:0;">
            <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 16px 0;">
              <span class="info-card-title" style="margin:0;">Affected Items</span>
              <button class="btn-outline btn-sm">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export
              </button>
            </div>
            <div class="table-scroll" style="margin-top:10px;" id="affected-table-wrap"></div>
          </div>
        </div>

        <div id="tab-impact" class="tab-panel">
          <div class="info-card"><div class="info-card-title">Business Impact</div><p class="info-card-body" id="impact-biz-body"></p></div>
          <div class="info-card"><div class="info-card-title">Possible Causes</div><p class="info-card-body" id="impact-causes-body"></p></div>
        </div>

        <div id="tab-resolution" class="tab-panel">
          <div class="info-card"><div class="info-card-title">What needs to change</div><p class="info-card-body" id="res-change-body"></p></div>
          <div class="info-card"><div class="info-card-title">What to consider before acting</div><p class="info-card-body" id="res-consider-body"></p></div>
          <div class="info-card"><div class="info-card-title">How to know the fix worked</div><p class="info-card-body" id="res-verify-body"></p></div>
        </div>

        <div id="tab-activity" class="tab-panel">
          <div class="table-card" style="margin-top:0;overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
              <thead><tr>
                <th class="th-small">TIMESTAMP</th>
                <th class="th-small">ACTION</th>
                <th class="th-small">NOTES</th>
                <th class="th-small">MODIFIED BY</th>
              </tr></thead>
              <tbody id="activity-tbody">
                <tr>
                  <td class="td-cell">Dec 4, 2025 at 8:32 AM</td>
                  <td class="td-cell"><span class="badge badge-warning">Rule triggered</span></td>
                  <td class="td-cell td-muted">—</td>
                  <td class="td-cell">Machine</td>
                </tr>
                <tr>
                  <td class="td-cell">Dec 4, 2025 at 9:15 AM</td>
                  <td class="td-cell"><span class="badge badge-info">Status updated</span></td>
                  <td class="td-cell td-muted">—</td>
                  <td class="td-cell">Shilo Jones</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

