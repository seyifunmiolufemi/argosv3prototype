      </table>
    </div>
  </div>
  <div style="margin-top:16px;">
    <button class="btn-outline" style="height:36px;padding:0 16px;font-size:13px;" onclick="hideRowDetailPage();switchDbTab('dataview');">← Back</button>
  </div>
