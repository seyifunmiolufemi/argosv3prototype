        <div class="alerts-filter-item" onclick="ovSetDate('Last 30 Days')">Last 30 Days</div>
        <div class="alerts-filter-item" onclick="ovSetDate('Last 90 Days')">Last 90 Days</div>
      </div>
    </div>
  </div>

  <!-- SEM CONTENT -->
  <div id="ov-sem-content">

    <!-- 1. KPI cards -->
    <div id="ov-sec-kpi" style="display:flex;gap:12px;margin-bottom:28px;flex-wrap:wrap;">
      <div class="ov-kpi-card">
        <div class="ov-kpi-label">Conversion Value</div>
        <div class="ov-kpi-value">$487,320</div>
        <div><span class="ov-kpi-change-pos">↑ +12.3%</span></div>
        <div class="ov-kpi-vs">vs Previous Period</div>
      </div>
      <div class="ov-kpi-card">
        <div class="ov-kpi-label">Cost</div>
        <div class="ov-kpi-value">$98,450</div>
        <div><span class="ov-kpi-change-neg">↓ -12.2%</span></div>
        <div class="ov-kpi-vs">vs Previous Period</div>
      </div>
      <div class="ov-kpi-card">
        <div class="ov-kpi-label">COS</div>
        <div class="ov-kpi-value">20.2%</div>
        <div><span class="ov-kpi-change-neg">↑ +12.2%</span></div>
        <div class="ov-kpi-vs">vs Previous Period</div>
      </div>
      <div class="ov-kpi-card">
        <div class="ov-kpi-label">Conversions</div>
        <div class="ov-kpi-value">3,847</div>
        <div><span class="ov-kpi-change-neg">↓ -12.2%</span></div>
        <div class="ov-kpi-vs">vs Previous Period</div>
      </div>
    </div>

    <!-- 2. Channel Performance -->
    <div id="ov-sec-channel" style="margin-bottom:28px;">
      <div class="table-card" style="padding:20px 24px;">
        <div class="ov-section-heading">Channel Performance Overview</div>
        <div class="ov-section-sub">How this channel is trending compared to the overall site and other key channels.</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
          <div>
            <div style="font-size:13px;font-weight:600;color:var(--color-text-primary);margin-bottom:12px;">Revenue</div>
            <div class="ov-bar-row"><div class="ov-bar-label">Paid Search</div><div class="ov-bar-track"><div class="ov-bar-fill" style="width:80%;background:var(--color-blue);"></div></div><div class="ov-bar-change-pos">+12.3%</div></div>
            <div class="ov-bar-row"><div class="ov-bar-label">Organic Search</div><div class="ov-bar-track"><div class="ov-bar-fill" style="width:30%;background:#9ca3af;"></div></div><div class="ov-bar-change-neg">-7.7%</div></div>
            <div class="ov-bar-row"><div class="ov-bar-label">Direct</div><div class="ov-bar-track"><div class="ov-bar-fill" style="width:45%;background:#9ca3af;"></div></div><div class="ov-bar-change-pos">+12.3%</div></div>
            <div class="ov-bar-row"><div class="ov-bar-label">Total Site</div><div class="ov-bar-track"><div class="ov-bar-fill" style="width:20%;background:#9ca3af;"></div></div><div class="ov-bar-change-neg">-3.6%</div></div>
          </div>
          <div>
            <div style="font-size:13px;font-weight:600;color:var(--color-text-primary);margin-bottom:12px;">Sessions</div>
            <div class="ov-bar-row"><div class="ov-bar-label">Paid Search</div><div class="ov-bar-track"><div class="ov-bar-fill" style="width:75%;background:var(--color-blue);"></div></div><div class="ov-bar-change-pos">+12.3%</div></div>
            <div class="ov-bar-row"><div class="ov-bar-label">Organic Search</div><div class="ov-bar-track"><div class="ov-bar-fill" style="width:35%;background:#9ca3af;"></div></div><div class="ov-bar-change-neg">-7.0%</div></div>
            <div class="ov-bar-row"><div class="ov-bar-label">Direct</div><div class="ov-bar-track"><div class="ov-bar-fill" style="width:40%;background:#9ca3af;"></div></div><div class="ov-bar-change-pos">+12.3%</div></div>
            <div class="ov-bar-row"><div class="ov-bar-label">Total Site</div><div class="ov-bar-track"><div class="ov-bar-fill" style="width:22%;background:#9ca3af;"></div></div><div class="ov-bar-change-neg">-3.6%</div></div>
          </div>
        </div>
        <p class="ov-section-insight" style="border-top:1px solid var(--color-border);padding-top:12px;margin-top:12px;">Paid Search revenue grew 12.3% while sessions increased 4.6%. Revenue per session improved, indicating better traffic quality or conversion efficiency.</p>
      </div>
    </div>

    <!-- 3. Performance Over Time -->
    <div id="ov-sec-time" style="margin-bottom:28px;">
      <div class="table-card" style="padding:20px 24px;">
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:4px;">
          <div class="ov-section-heading" style="margin-bottom:0;">Performance Over Time</div>
          <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
            <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--color-text-primary);cursor:pointer;">
              <input type="checkbox" id="ov-markers-cb" checked style="accent-color:var(--color-blue);"> Show special cause markers
            </label>
            <div style="position:relative;">
              <select class="modal-select" id="ov-metric-sel" style="font-size:13px;padding:5px 28px 5px 10px;">
                <option>Conversion Value</option>
                <option>Cost</option>
                <option>COS</option>
                <option>Conversions</option>
                <option>ROAS</option>
              </select>
            </div>
          </div>
        </div>
        <div class="ov-section-sub">How your key metrics are trending day over day.</div>
        <!-- SVG Line Chart -->
        <div style="width:100%;overflow-x:auto;">
          <svg viewBox="0 0 860 200" style="width:100%;min-width:500px;display:block;" xmlns="http://www.w3.org/2000/svg">
            <!-- Y axis labels -->
            <text x="0" y="18" font-size="10" fill="#9ca3af">$600K</text>
            <text x="0" y="58" font-size="10" fill="#9ca3af">$500K</text>
            <text x="0" y="98" font-size="10" fill="#9ca3af">$400K</text>
            <text x="0" y="138" font-size="10" fill="#9ca3af">$300K</text>
            <text x="0" y="178" font-size="10" fill="#9ca3af">$200K</text>
            <!-- Grid lines -->
            <line x1="40" y1="14" x2="855" y2="14" stroke="#e2e5ed" stroke-width="1"/>
            <line x1="40" y1="54" x2="855" y2="54" stroke="#e2e5ed" stroke-width="1"/>
            <line x1="40" y1="94" x2="855" y2="94" stroke="#e2e5ed" stroke-width="1"/>
            <line x1="40" y1="134" x2="855" y2="134" stroke="#e2e5ed" stroke-width="1"/>
            <line x1="40" y1="174" x2="855" y2="174" stroke="#e2e5ed" stroke-width="1"/>
            <!-- Chart line -->
            <polyline points="40,140 95,120 150,130 205,100 260,115 315,90 370,105 425,80 480,95 535,70 590,88 645,60 700,75 755,55 810,65 855,50" fill="none" stroke="#346ed9" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>
            <!-- Area fill -->
            <polygon points="40,140 95,120 150,130 205,100 260,115 315,90 370,105 425,80 480,95 535,70 590,88 645,60 700,75 755,55 810,65 855,50 855,174 40,174" fill="rgba(52,110,217,0.07)"/>
            <!-- X axis labels -->
            <text x="40" y="195" font-size="9" fill="#9ca3af" text-anchor="middle">Aug 25</text>
            <text x="150" y="195" font-size="9" fill="#9ca3af" text-anchor="middle">Sep 15</text>
            <text x="260" y="195" font-size="9" fill="#9ca3af" text-anchor="middle">Oct 5</text>
            <text x="370" y="195" font-size="9" fill="#9ca3af" text-anchor="middle">Oct 26</text>
            <text x="480" y="195" font-size="9" fill="#9ca3af" text-anchor="middle">Nov 15</text>
            <text x="590" y="195" font-size="9" fill="#9ca3af" text-anchor="middle">Dec 5</text>
            <text x="700" y="195" font-size="9" fill="#9ca3af" text-anchor="middle">Dec 20</text>
            <text x="855" y="195" font-size="9" fill="#9ca3af" text-anchor="middle">Dec 31</text>
          </svg>
        </div>
        <div style="margin-top:8px;">
          <span style="display:inline-flex;align-items:center;gap:5px;background:var(--color-container-info);border:1px solid #c7d9f8;border-radius:20px;padding:3px 10px;font-size:12px;color:var(--color-blue);cursor:pointer;">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="5" stroke="#346ed9" stroke-width="1.2"/><path d="M6 4v2.5M6 7.5v.5" stroke="#346ed9" stroke-width="1.2" stroke-linecap="round"/></svg>
            1 Connected Issue
          </span>
        </div>
      </div>
    </div>

    <!-- 4. Drivers of Change -->
    <div id="ov-sec-drivers" style="margin-bottom:28px;">
      <div class="table-card" style="padding:20px 24px;">
        <div class="ov-section-heading">Drivers of Change</div>
        <div class="ov-section-sub">Breakdown of factors behind the change from the previous period.</div>
        <div style="width:100%;overflow-x:auto;">
          <svg viewBox="0 0 700 220" style="width:100%;min-width:500px;display:block;" xmlns="http://www.w3.org/2000/svg">
            <line x1="50" y1="30" x2="690" y2="30" stroke="#e2e5ed" stroke-width="1"/>
            <line x1="50" y1="110" x2="690" y2="110" stroke="#e2e5ed" stroke-width="1"/>
            <line x1="50" y1="190" x2="690" y2="190" stroke="#e2e5ed" stroke-width="1"/>
            <text x="45" y="34" font-size="9" fill="#9ca3af" text-anchor="end" font-family="DM Sans,sans-serif">$500K</text>
            <text x="45" y="114" font-size="9" fill="#9ca3af" text-anchor="end" font-family="DM Sans,sans-serif">$250K</text>
            <text x="45" y="194" font-size="9" fill="#9ca3af" text-anchor="end" font-family="DM Sans,sans-serif">$0</text>
            <!-- Prev Period: grey, y=62 to y=190, height=128 (~$352K) -->
            <rect x="60" y="62" width="60" height="128" fill="#d1d5db" rx="2"/>
            <text x="90" y="57" font-size="8" fill="#6b7280" text-anchor="middle" font-family="DM Sans,sans-serif">$352K</text>
            <text x="90" y="210" font-size="9" fill="#6b7280" text-anchor="middle" font-family="DM Sans,sans-serif">Prev Period</text>
            <line x1="120" y1="62" x2="150" y2="62" stroke="#9ca3af" stroke-width="1" stroke-dasharray="4,3"/>
            <!-- Impressions: green float from y=62, height=25, top=37 -->
            <rect x="150" y="37" width="60" height="25" fill="#22c55e" rx="2"/>
            <text x="180" y="30" font-size="8" fill="#166534" text-anchor="middle" font-family="DM Sans,sans-serif">+$58.2K</text>
            <text x="180" y="210" font-size="9" fill="#6b7280" text-anchor="middle" font-family="DM Sans,sans-serif">Impressions</text>
            <line x1="210" y1="37" x2="240" y2="37" stroke="#9ca3af" stroke-width="1" stroke-dasharray="4,3"/>
            <!-- Clicks: green float from y=37, height=20, top=17 -->
            <rect x="240" y="17" width="60" height="20" fill="#22c55e" rx="2"/>
            <text x="270" y="12" font-size="8" fill="#166534" text-anchor="middle" font-family="DM Sans,sans-serif">+$41.1K</text>
            <text x="270" y="210" font-size="9" fill="#6b7280" text-anchor="middle" font-family="DM Sans,sans-serif">Clicks</text>
            <line x1="300" y1="17" x2="330" y2="17" stroke="#9ca3af" stroke-width="1" stroke-dasharray="4,3"/>
            <!-- Conv. Rate: green float from y=10, height=30 (largest) -->
            <rect x="330" y="10" width="60" height="30" fill="#22c55e" rx="2"/>
            <text x="360" y="6" font-size="8" fill="#166534" text-anchor="middle" font-family="DM Sans,sans-serif">+$68.4K</text>
            <text x="360" y="210" font-size="9" fill="#6b7280" text-anchor="middle" font-family="DM Sans,sans-serif">Conv. Rate</text>
            <line x1="390" y1="10" x2="420" y2="10" stroke="#9ca3af" stroke-width="1" stroke-dasharray="4,3"/>
            <!-- AOV: red, negative, from y=10, height=15 -->
            <rect x="420" y="10" width="60" height="15" fill="#ef4444" rx="2"/>
            <text x="450" y="6" font-size="8" fill="#991b1b" text-anchor="middle" font-family="DM Sans,sans-serif">-$12.8K</text>
            <text x="450" y="210" font-size="9" fill="#6b7280" text-anchor="middle" font-family="DM Sans,sans-serif">AOV</text>
            <line x1="480" y1="25" x2="510" y2="25" stroke="#9ca3af" stroke-width="1" stroke-dasharray="4,3"/>
            <!-- Curr Period: grey, y=25 to y=190, height=165 (~$507K) -->
            <rect x="510" y="25" width="60" height="165" fill="#d1d5db" rx="2"/>
            <text x="540" y="20" font-size="8" fill="#6b7280" text-anchor="middle" font-family="DM Sans,sans-serif">$507K</text>
            <text x="540" y="210" font-size="9" fill="#6b7280" text-anchor="middle" font-family="DM Sans,sans-serif">Curr Period</text>
          </svg>
        </div>
        <p class="ov-section-insight" style="border-top:1px solid var(--color-border);padding-top:12px;margin-top:4px;">Conversion Rate has the largest directional association with the period-over-period change, relative to other factors.</p>
      </div>
    </div>

    <!-- 5. Category Performance -->
    <div id="ov-sec-category" style="margin-bottom:28px;">
      <div class="table-card">
        <div style="padding:20px 24px 12px;">
          <div class="ov-section-heading">Category Performance</div>
          <div class="ov-section-sub" style="margin-bottom:0;">Performance by product category across revenue, cost, and efficiency.</div>
        </div>
        <table style="width:100%;border-collapse:collapse;">
          <thead>
            <tr style="background:var(--color-bg-grey50);border-bottom:1px solid var(--color-border);">
              <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-caption);padding:10px 16px;text-align:left;">Category</th>
              <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-caption);padding:10px 16px;text-align:right;">Conv. Val.</th>
              <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-caption);padding:10px 16px;text-align:right;">Cost</th>
              <th style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-caption);padding:10px 16px;text-align:right;">Conv</th>
