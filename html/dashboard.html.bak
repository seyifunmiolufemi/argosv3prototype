        <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div id="ov-client-panel" class="alerts-filter-panel" style="min-width:200px;">
        <div class="alerts-filter-item" onclick="ovSetClient('Outdoor Research')">Outdoor Research</div>
        <div class="alerts-filter-item" onclick="ovSetClient('MojoMotoSport')">MojoMotoSport</div>
        <div class="alerts-filter-item" onclick="ovSetClient('Blossom Beauty')">Blossom Beauty</div>
        <div class="alerts-filter-item" onclick="ovSetClient('Peak Performance')">Peak Performance</div>
