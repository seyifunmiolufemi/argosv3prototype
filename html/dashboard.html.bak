<!-- ══ ADD DATABASE MODAL ══ -->
<div id="add-db-modal" style="display:none;position:fixed;inset:0;background:rgba(1,3,7,0.45);z-index:9999;align-items:center;justify-content:center;">
  <div class="modal-box" style="width:400px;padding:0;max-height:90vh;overflow-y:auto;">
    <div class="add-db-modal-header">
      <span class="modal-title" style="font-size:16px;font-weight:600;">Add Database</span>
      <button onclick="closeAddDbModal()" style="background:none;border:none;cursor:pointer;font-size:20px;color:var(--color-text-caption);line-height:1;padding:0 2px;">×</button>
    </div>
    <div class="add-db-modal-body">
      <!-- Database name -->
      <div>
        <label class="field-label">Database name <span class="field-required">*</span></label>
        <input type="text" id="add-db-name" class="modal-input" placeholder="Enter database name">
        <div class="field-error" id="add-db-name-error">Database name is required.</div>
      </div>
      <!-- Client -->
      <div>
        <label class="field-label">Client</label>
        <select id="add-db-client" class="modal-select">
          <option value="">Select client</option>
        </select>
      </div>
      <!-- Group -->
      <div>
        <label class="field-label">Group</label>
        <select id="add-db-group" class="modal-select" onchange="handleAddDbGroupChange(this.value)">
          <option value="">None (Ungrouped)</option>
          <option value="monkey-sports">Monkey Sports</option>
          <option value="__new__">+ Create new group</option>
        </select>
        <div id="add-db-new-group-wrap" style="display:none;" class="new-group-input-row">
          <input type="text" id="add-db-new-group-name" class="modal-input" placeholder="Enter group name" style="margin:0;">
          <button class="btn-danger-icon" onclick="clearNewGroup()" title="Cancel">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
          </button>
        </div>
        <div class="field-helper">Grouping databases allows easier organization for clients with multiple sites.</div>
      </div>
    </div>
    <div class="add-db-modal-footer">
      <button class="btn-primary-sm" onclick="submitAddDb()">Add Database</button>
      <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="closeAddDbModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- ══ DATABASE OVERVIEW PAGE ══ -->
<div id="db-overview-page" style="display:none;">

  <!-- Page header -->
  <div class="page-title-row">
    <div class="page-title-left">
      <h1 class="page-h1" id="db-overview-title">Database Name</h1>
      <div class="db-pills-row">
        <span class="db-pill" id="db-overview-client-pill">Client: —</span>
        <span class="db-pill" id="db-overview-group-pill">Ungrouped</span>
      </div>
    </div>
  </div>

  <nav class="breadcrumb" style="margin-bottom:20px;">
    <span class="bc-item bc-muted">Tools</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showFeedDataPage()">Feed Data Tool</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-muted" style="cursor:pointer;" onclick="showFeedDataPage()">Feed Database</span>
    <span class="bc-item bc-muted">›</span>
    <span class="bc-item bc-current" id="db-overview-bc-name">Database</span>
  </nav>

  <!-- Tab bar -->
  <div class="detail-tabs-bar" id="db-tabs-bar">
    <button class="detail-tab active" data-dbtab="overview">Overview</button>
    <button class="detail-tab" data-dbtab="imports">Imports</button>
    <button class="detail-tab" data-dbtab="dataview">Data View</button>
    <button class="detail-tab" data-dbtab="transformers">Transformers</button>
    <button class="detail-tab" data-dbtab="exports">Exports</button>
    <button class="detail-tab" data-dbtab="logs">Logs</button>
  </div>

  <!-- Overview tab panel -->
  <div class="tab-panel active" id="db-tab-overview">
    <div style="margin-top:20px;">
      <p class="page-h1" style="font-size:16px;margin-bottom:2px;">Overview</p>
      <p class="page-subtitle" style="text-align:left;">A summary of your database activity and health</p>
    </div>

    <!-- Action cards -->
    <div class="action-cards-row">
      <div class="action-card" onclick="switchDbTab('imports')">
        <div class="action-card-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </div>
        <span class="action-card-title">Run Import</span>
        <span class="action-card-arrow">→</span>
      </div>
      <div class="action-card" onclick="switchDbTab('dataview')">
        <div class="action-card-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <span class="action-card-title">View Data</span>
        <span class="action-card-arrow">→</span>
      </div>
      <div class="action-card" onclick="switchDbTab('exports')">
        <div class="action-card-icon">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
        </div>
        <span class="action-card-title">Run Export</span>
        <span class="action-card-arrow">→</span>
      </div>
    </div>

    <!-- Stats row -->
    <div class="stats-row">
      <div class="stat-block">
        <div class="stat-block-value">24,338</div>
        <div class="stat-block-label">Total SKUs</div>
      </div>
      <div class="stat-block">
        <div class="stat-block-value">2</div>
        <div class="stat-block-label">Imports Scheduled</div>
        <div class="stat-block-sub">Last: 1hr ago</div>
      </div>
      <div class="stat-block">
        <div class="stat-block-value">2</div>
        <div class="stat-block-label">Exports Scheduled</div>
        <div class="stat-block-sub">Last: 1hr ago</div>
      </div>
    </div>

    <!-- Recent Activities -->
    <div style="margin-top:24px;">
      <p style="font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;color:var(--color-text-primary);margin-bottom:12px;">Recent Activities</p>
      <div class="table-card" style="padding:0;">
        <div class="table-scroll">
          <table class="feed-table" style="table-layout:fixed;width:100%;">
            <colgroup><col style="width:52%;"><col style="width:16%;"><col style="width:32%;"></colgroup>
            <thead>
              <tr>
                <th>Activity</th>
                <th>Status</th>
                <th style="text-align:left;">Modified By</th>
              </tr>
            </thead>
            <tbody>
              <tr><td style="font-size:13px;color:var(--color-text-primary);">Export to Google Merchant Center completed · 14,523 items</td><td><span class="badge" style="background:var(--color-container-success);color:var(--color-text-success);border-radius:20px;padding:3px 10px;font-size:12px;font-weight:500;">Completed</span></td><td><div class="modified-by-cell"><span class="avatar-circle avatar-system" style="font-size:9px;">S</span><div class="modified-by-info"><span class="modified-by-name">System</span><span class="modified-by-time">30 mins ago</span></div></div></td></tr>
              <tr><td style="font-size:13px;color:var(--color-text-primary);">Export to Microsoft Merchant Center completed · 14,521 items</td><td><span class="badge" style="background:var(--color-container-success);color:var(--color-text-success);border-radius:20px;padding:3px 10px;font-size:12px;font-weight:500;">Completed</span></td><td><div class="modified-by-cell"><span class="avatar-circle avatar-system" style="font-size:9px;">S</span><div class="modified-by-info"><span class="modified-by-name">System</span><span class="modified-by-time">32 mins ago</span></div></div></td></tr>
              <tr><td style="font-size:13px;color:var(--color-text-primary);">Import from Shopify completed · 14,612 items</td><td><span class="badge" style="background:var(--color-container-success);color:var(--color-text-success);border-radius:20px;padding:3px 10px;font-size:12px;font-weight:500;">Completed</span></td><td><div class="modified-by-cell"><span class="avatar-circle avatar-system" style="font-size:9px;">S</span><div class="modified-by-info"><span class="modified-by-name">System</span><span class="modified-by-time">32 mins ago</span></div></div></td></tr>
              <tr><td style="font-size:13px;color:var(--color-text-primary);">Transformer 'Clear invalid image links' created</td><td><span class="badge" style="background:var(--color-container-success);color:var(--color-text-success);border-radius:20px;padding:3px 10px;font-size:12px;font-weight:500;">Completed</span></td><td><div class="modified-by-cell"><span class="avatar-circle avatar-person">AS</span><div class="modified-by-info"><span class="modified-by-name">Amy Sams</span><span class="modified-by-time">2 hours ago</span></div></div></td></tr>
              <tr><td style="font-size:13px;color:var(--color-text-primary);">Transformer 'Fix price format USD' modified</td><td><span class="badge" style="background:var(--color-container-success);color:var(--color-text-success);border-radius:20px;padding:3px 10px;font-size:12px;font-weight:500;">Completed</span></td><td><div class="modified-by-cell"><span class="avatar-circle avatar-person">AS</span><div class="modified-by-info"><span class="modified-by-name">Amy Sams</span><span class="modified-by-time">2 hours ago</span></div></div></td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Imports tab panel -->
  <div class="tab-panel" id="db-tab-imports">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-top:20px;gap:12px;">
      <div>
        <p class="page-h1" style="font-size:16px;margin-bottom:2px;">Imports</p>
        <p class="page-subtitle">Manage your data sources and import schedules</p>
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex-shrink:0;">
        <button class="btn-outline" style="height:36px;padding:0 14px;" onclick="showFieldMappingPage()">Field Mapping</button>
        <button class="btn-primary-sm" onclick="showAddImportPage()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Import
        </button>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:10px;margin-top:16px;margin-bottom:16px;">
      <div class="search-box" style="flex:1;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#737c8c" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" placeholder="Search imports...">
      </div>
      <button class="btn-outline" style="display:inline-flex;align-items:center;gap:6px;padding:0 14px;height:36px;">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
        Filters
      </button>
    </div>
    <div class="table-card" style="padding:0;">
      <div class="table-scroll">
        <table class="feed-table" id="imports-table" style="table-layout:fixed;width:100%;">
          <colgroup>
            <col style="width:22%;">
            <col style="width:16%;">
            <col style="width:12%;">
            <col style="width:18%;">
            <col style="width:10%;">
            <col style="width:18%;">
            <col style="width:4%;">
          </colgroup>
          <thead>
            <tr>
              <th>Name</th>
              <th>Source</th>
              <th>Type</th>
              <th>Schedule</th>
              <th>From</th>
              <th>Last Run</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="imports-tbody">
            <tr class="feed-row"><td><span class="feed-name">Shopify Products</span></td><td><span style="display:inline-flex;align-items:center;"><span class="source-dot" style="background:#96bf48;"></span>Shopify</span></td><td>Main Feed</td><td>Every four hours</td><td>14,812</td><td>Feb 1, 2:00 PM UTC</td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">View Details</div><div class="dd-item">Edit Import</div><div class="dd-item">Pause Import</div><div style="height:1px;background:var(--color-border);margin:4px 2px;"></div><div class="dd-item danger">Delete Import</div></div></div></td></tr>
            <tr class="feed-row"><td><span class="feed-name">Inventory Levels</span></td><td><span style="display:inline-flex;align-items:center;"><span class="source-dot" style="background:#6b7280;"></span>CSV</span></td><td>Join</td><td>Every 15 mins</td><td>14,812</td><td>Feb 1, 2:00 PM UTC</td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">View Details</div><div class="dd-item">Edit Import</div><div class="dd-item">Pause Import</div><div style="height:1px;background:var(--color-border);margin:4px 2px;"></div><div class="dd-item danger">Delete Import</div></div></div></td></tr>
            <tr class="feed-row"><td><span class="feed-name">Pricing Override</span></td><td><span style="display:inline-flex;align-items:center;"><span class="source-dot" style="background:#6b7280;"></span>SFTP</span></td><td>Join</td><td>Daily at 9:00 AM</td><td>14,812</td><td>Feb 1, 2:00 PM UTC</td><td><div class="feed-action-wrap"><button class="feed-action-btn">⋮</button><div class="feed-action-menu"><div class="dd-item">View Details</div><div class="dd-item">Edit Import</div><div class="dd-item">Pause Import</div><div style="height:1px;background:var(--color-border);margin:4px 2px;"></div><div class="dd-item danger">Delete Import</div></div></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══ DATA VIEW TAB ══ -->
  <div class="tab-panel" id="db-tab-dataview">
    <!-- top bar -->
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:14px;">
      <div>
        <h3 style="font-family:'Instrument Sans',sans-serif;font-size:18px;font-weight:600;margin:0 0 3px;">Data View</h3>
        <p style="font-size:13px;color:var(--color-text-caption);margin:0;">View and search your product data</p>
      </div>
      <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
        <span style="font-size:13px;color:var(--color-text-caption);">Data View <strong style="color:var(--color-text-primary);">51,395</strong> rows</span>
        <!-- View dropdown -->
        <div style="position:relative;" id="dv-view-wrap">
          <button class="btn-filter" id="dv-view-btn" onclick="toggleDvPanel('view')">
            <span id="dv-view-label">View: Raw Data</span>
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="custom-dd-panel" id="dv-view-panel" style="min-width:160px;">
            <div class="custom-dd-item active" onclick="setDvView('Raw Data')">Raw Data</div>
            <div class="custom-dd-item" onclick="setDvView('Transformed Data')">Transformed Data</div>
          </div>
        </div>
        <button class="btn-primary-sm" onclick="dvDownloadAll()">Download Data</button>
      </div>
    </div>
    <!-- search row -->
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:14px;">
      <!-- Fields dropdown -->
      <div style="position:relative;" id="dv-fields-wrap">
        <button class="btn-filter" id="dv-fields-btn" onclick="toggleDvPanel('fields')">
          <span id="dv-fields-label">All fields</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="custom-dd-panel" id="dv-fields-panel" style="min-width:220px;max-height:280px;overflow-y:auto;">
          <label style="display:flex;align-items:center;gap:8px;padding:5px 4px;font-size:13px;cursor:pointer;"><input type="checkbox" id="dv-fields-all" checked onchange="dvToggleAllFields(this)"> <strong>All fields</strong></label>
          <hr style="border:none;border-top:1px solid var(--color-border);margin:4px 0;">
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="id" checked> id</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="title" checked> title</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="price" checked> price</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="sale_price" checked> sale_price</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="brand" checked> brand</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="availability" checked> availability</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="condition" checked> condition</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="product_type" checked> product_type</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="google_product_category" checked> google_product_category</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="item_group_id" checked> item_group_id</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="color" checked> color</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="description" checked> description</label>
          <label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;"><input type="checkbox" class="dv-field-cb" data-field="link" checked> link</label>
        </div>
      </div>
      <!-- Operator dropdown -->
      <div style="position:relative;" id="dv-op-wrap">
        <button class="btn-filter" id="dv-op-btn" onclick="toggleDvPanel('op')">
          <span id="dv-op-label">Contains</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="custom-dd-panel" id="dv-op-panel" style="min-width:180px;">
          <div class="custom-dd-item active" onclick="setDvOp('Contains')">Contains</div>
          <div class="custom-dd-item" onclick="setDvOp('Does not contain')">Does not contain</div>
          <div class="custom-dd-item" onclick="setDvOp('Equals')">Equals</div>
          <div class="custom-dd-item" onclick="setDvOp('Starts with')">Starts with</div>
          <div class="custom-dd-item" onclick="setDvOp('Is empty')">Is empty</div>
          <div class="custom-dd-item" onclick="setDvOp('Is not empty')">Is not empty</div>
        </div>
      </div>
      <input type="text" id="dv-keyword" class="modal-input" placeholder="Enter keyword..." style="padding:8px 11px;font-size:14px;flex:1;min-width:140px;" onkeydown="if(event.key==='Enter')dvSearch()">
      <!-- Columns dropdown -->
      <div style="position:relative;" id="dv-cols-wrap">
        <button class="btn-filter" id="dv-cols-btn" onclick="toggleDvPanel('cols')">
          Columns: All
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="custom-dd-panel" id="dv-cols-panel" style="min-width:240px;max-height:340px;overflow-y:auto;right:0;left:auto;">
          <input type="text" class="modal-input" placeholder="Search columns" style="padding:6px 9px;font-size:13px;margin-bottom:6px;width:100%;box-sizing:border-box;" oninput="dvFilterColPanel(this.value)">
          <label style="display:flex;align-items:center;gap:8px;padding:5px 4px;font-size:13px;cursor:pointer;"><input type="checkbox" id="dv-cols-all" checked onchange="dvToggleAllCols(this)"> <strong>Select all</strong></label>
          <hr style="border:none;border-top:1px solid var(--color-border);margin:4px 0;">
          <div id="dv-col-rows">
            <div class="dv-col-row" data-col-name="id"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="2" checked> id</label><button onclick="dvDownloadCol('id')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="title"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="3" checked> title</label><button onclick="dvDownloadCol('title')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="price"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="4" checked> price</label><button onclick="dvDownloadCol('price')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="sale_price"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="5" checked> sale_price</label><button onclick="dvDownloadCol('sale_price')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="brand"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="6" checked> brand</label><button onclick="dvDownloadCol('brand')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="availability"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="7" checked> availability</label><button onclick="dvDownloadCol('availability')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="condition"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="8" checked> condition</label><button onclick="dvDownloadCol('condition')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="product_type"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="9" checked> product_type</label><button onclick="dvDownloadCol('product_type')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="google_product_category"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="10" checked> google_product_category</label><button onclick="dvDownloadCol('google_product_category')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="item_group_id"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="11" checked> item_group_id</label><button onclick="dvDownloadCol('item_group_id')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="color"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="12" checked> color</label><button onclick="dvDownloadCol('color')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="description"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="13" checked> description</label><button onclick="dvDownloadCol('description')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
            <div class="dv-col-row" data-col-name="link"><label style="display:flex;align-items:center;gap:8px;padding:4px;font-size:13px;cursor:pointer;flex:1;"><input type="checkbox" class="dv-col-toggle" data-col-index="14" checked> link</label><button onclick="dvDownloadCol('link')" style="background:none;border:none;cursor:pointer;color:var(--color-blue);font-size:14px;padding:4px;" title="Download column">↓</button></div>
          </div>
          <button class="btn-primary-sm" style="width:100%;margin-top:8px;justify-content:center;" onclick="dvDownloadAll()">Download (All)</button>
        </div>
      </div>
