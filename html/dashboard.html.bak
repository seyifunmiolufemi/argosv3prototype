    <strong id="pm-flyout-title" style="font-size:14px;color:var(--color-text-primary);"></strong>
    <button onclick="document.getElementById('pm-perm-flyout').style.display='none'" style="background:none;border:none;cursor:pointer;font-size:18px;color:var(--color-text-caption);line-height:1;padding:0;">×</button>
  </div>
  <table class="pm-perm-table" id="pm-flyout-table"></table>
</div>

<!-- ══ ADD TRANSFORMER MODAL ══ -->
<div id="add-transformer-modal" style="display:none;position:fixed;inset:0;background:rgba(1,3,7,0.4);z-index:9999;align-items:center;justify-content:center;">
  <div class="modal-box" style="max-width:480px;width:92%;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h3 class="modal-title" style="margin:0;">Add Transformer</h3>
      <button onclick="closeAddTransformerModal()" style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--color-text-caption);line-height:1;">×</button>
    </div>
    <!-- IF section -->
    <div style="margin-bottom:16px;">
      <div style="display:flex;align-items:center;gap:8px;font-size:14px;font-weight:600;margin-bottom:12px;">
        <span class="chip-if" style="font-size:12px;padding:2px 7px;">IF</span>
        <span>Condition</span>
      </div>
      <div style="display:flex;gap:10px;margin-bottom:10px;">
        <div style="flex:1;">
          <label class="field-label" style="font-size:12px;">Field</label>
          <select class="modal-select" id="tf-modal-if-field" style="font-size:13px;padding:7px 10px;">
            <option>title</option><option>description</option><option>brand</option><option>id</option><option>price</option><option>sale_price</option><option>condition</option><option>availability</option><option>product_type</option><option>google_product_category</option><option>item_group_id</option><option>color</option><option>custom_label_0</option><option>custom_label_1</option><option>custom_label_2</option>
          </select>
        </div>
        <div style="flex:1;">
          <label class="field-label" style="font-size:12px;">Operator</label>
          <select class="modal-select" id="tf-modal-if-op" style="font-size:13px;padding:7px 10px;">
            <option>contains</option><option>does not contain</option><option>equals</option><option>does not equal</option><option>starts with</option><option>ends with</option><option>is empty</option><option>is not empty</option><option>matches regex</option>
          </select>
        </div>
      </div>
      <div>
        <label class="field-label" style="font-size:12px;">Value</label>
        <input type="text" id="tf-modal-if-val" class="modal-input" placeholder='e.g. "Tandem"' style="font-size:13px;padding:7px 10px;">
      </div>
    </div>
    <div style="height:1px;background:var(--color-border);margin-bottom:16px;"></div>
    <!-- THEN section -->
    <div style="margin-bottom:16px;">
      <div style="display:flex;align-items:center;gap:8px;font-size:14px;font-weight:600;margin-bottom:12px;">
        <span class="chip-then" style="font-size:12px;padding:2px 7px;">THEN</span>
        <span>Action</span>
      </div>
      <div style="display:flex;gap:10px;margin-bottom:10px;">
        <div style="flex:1;">
          <label class="field-label" style="font-size:12px;">Target Field</label>
          <select class="modal-select" id="tf-modal-then-field" style="font-size:13px;padding:7px 10px;">
            <option>title</option><option>description</option><option>brand</option><option>id</option><option>price</option><option>sale_price</option><option>condition</option><option>availability</option><option>product_type</option><option>google_product_category</option>
          </select>
        </div>
        <div style="flex:1;">
          <label class="field-label" style="font-size:12px;">Action</label>
          <select class="modal-select" id="tf-modal-then-action" style="font-size:13px;padding:7px 10px;">
            <option>Set to</option><option>Replace</option><option>Append</option><option>Prepend</option><option>To lowercase</option><option>To uppercase</option><option>Remove HTML</option><option>Truncate to</option><option>Set to empty</option>
          </select>
        </div>
      </div>
      <div>
        <label class="field-label" style="font-size:12px;">Value</label>
        <input type="text" id="tf-modal-then-val" class="modal-input" placeholder='e.g. "Tandem Sport"' style="font-size:13px;padding:7px 10px;">
      </div>
    </div>
    <div style="margin-bottom:16px;">
      <label class="field-label" style="font-size:12px;">Apply to Exports</label>
      <select class="modal-select" style="font-size:13px;padding:7px 10px;">
        <option selected>All Exports</option><option>Google Shopping</option><option>Bing Ads</option><option>Facebook</option><option>Klorija</option>
      </select>
    </div>
    <div style="display:flex;gap:10px;align-items:center;margin-top:4px;">
      <button class="btn-primary-sm" onclick="submitAddTransformer()">Add Transformer</button>
      <button class="btn-text-link grey" onclick="closeAddTransformerModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- ══ FIELD EXECUTION ORDER MODAL ══ -->
<div id="field-exec-order-modal" style="display:none;position:fixed;inset:0;background:rgba(1,3,7,0.4);z-index:9999;align-items:center;justify-content:center;">
  <div class="modal-box" style="max-width:400px;width:92%;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h3 class="modal-title" style="margin:0;">Field Execution Order</h3>
      <button onclick="closeFieldExecOrderModal()" style="background:none;border:none;font-size:20px;cursor:pointer;color:var(--color-text-caption);line-height:1;">×</button>
    </div>
    <table class="feed-table" style="font-size:13px;">
      <colgroup><col style="width:36px;"><col style="width:auto;"><col style="width:60px;"></colgroup>
      <thead><tr><th></th><th>Field Name</th><th>Order</th></tr></thead>
      <tbody id="exec-order-tbody">
        <tr draggable="true" ondragstart="execOrderDragStart(event,this)" ondragover="execOrderDragOver(event)" ondrop="execOrderDrop(event,this)"><td style="cursor:grab;color:var(--color-text-caption);text-align:center;">⋮⋮</td><td>id</td><td class="exec-order-num">0</td></tr>
        <tr draggable="true" ondragstart="execOrderDragStart(event,this)" ondragover="execOrderDragOver(event)" ondrop="execOrderDrop(event,this)"><td style="cursor:grab;color:var(--color-text-caption);text-align:center;">⋮⋮</td><td>title</td><td class="exec-order-num">1</td></tr>
        <tr draggable="true" ondragstart="execOrderDragStart(event,this)" ondragover="execOrderDragOver(event)" ondrop="execOrderDrop(event,this)"><td style="cursor:grab;color:var(--color-text-caption);text-align:center;">⋮⋮</td><td>description</td><td class="exec-order-num">2</td></tr>
        <tr draggable="true" ondragstart="execOrderDragStart(event,this)" ondragover="execOrderDragOver(event)" ondrop="execOrderDrop(event,this)"><td style="cursor:grab;color:var(--color-text-caption);text-align:center;">⋮⋮</td><td>brand</td><td class="exec-order-num">3</td></tr>
        <tr draggable="true" ondragstart="execOrderDragStart(event,this)" ondragover="execOrderDragOver(event)" ondrop="execOrderDrop(event,this)"><td style="cursor:grab;color:var(--color-text-caption);text-align:center;">⋮⋮</td><td>product_type</td><td class="exec-order-num">4</td></tr>
        <tr draggable="true" ondragstart="execOrderDragStart(event,this)" ondragover="execOrderDragOver(event)" ondrop="execOrderDrop(event,this)"><td style="cursor:grab;color:var(--color-text-caption);text-align:center;">⋮⋮</td><td>condition</td><td class="exec-order-num">5</td></tr>
        <tr draggable="true" ondragstart="execOrderDragStart(event,this)" ondragover="execOrderDragOver(event)" ondrop="execOrderDrop(event,this)"><td style="cursor:grab;color:var(--color-text-caption);text-align:center;">⋮⋮</td><td>google_product_category</td><td class="exec-order-num">6</td></tr>
      </tbody>
    </table>
    <div class="modal-footer" style="margin-top:16px;display:flex;gap:10px;align-items:center;">
      <button class="btn-primary-sm" onclick="closeFieldExecOrderModal();showToast('Execution order saved')">Save Order</button>
      <button class="btn-text-link grey" onclick="closeFieldExecOrderModal()">Cancel</button>
    </div>
  </div>
</div>

<!-- ══ RESOLVE MODAL ══ -->
<div id="resolve-modal" style="display:none;position:fixed;inset:0;background:rgba(1,3,7,0.4);z-index:9999;align-items:center;justify-content:center;">
  <div class="modal-box">
    <h3 class="modal-title">Mark as Resolved</h3>
    <p class="modal-desc">You are manually marking this issue as resolved. The system will continue to run checks on the next scheduled run.</p>
    <div class="modal-field">
      <label class="modal-label">Note (Optional)</label>
      <textarea id="resolve-note" class="modal-textarea" placeholder="e.g. Confirmed conflict was intentional — negative added deliberately to prevent tier overlap. No action needed."></textarea>
    </div>
    <p class="modal-hint">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      This note will be available in the Activity Log
    </p>
    <div class="modal-footer">
      <button class="btn-outline" id="modal-cancel">Cancel</button>
      <button class="btn-primary-sm" id="modal-confirm">Mark as Resolved</button>
    </div>
  </div>
</div>

<div id="toast-msg" class="toast"></div>
<!-- Shopify Setup Modal -->
<div id="shopify-modal" style="display:none;position:fixed;inset:0;background:rgba(1,3,7,0.3);z-index:9998;align-items:flex-start;justify-content:flex-start;padding-left:228px;opacity:0;transition:opacity 0.22s ease;">
  <div class="modal-box" style="position:relative;max-width:380px;transform:translateX(-12px);transition:transform 0.25s ease;">
    <!-- Speech bubble tail pointing left toward Settings in sidebar -->
    <div style="position:absolute;left:-9px;top:18px;width:0;height:0;border-top:9px solid transparent;border-bottom:9px solid transparent;border-right:9px solid var(--color-white);pointer-events:none;"></div>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;">
      <div style="width:32px;height:32px;border-radius:8px;background:var(--color-container-warn);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </div>
      <h3 class="modal-title">Connect your store to unlock the full picture</h3>
    </div>
    <p class="modal-desc">Your ad accounts are connected and StatBid can see your spend and clicks. But without your Shopify store, StatBid can't see orders, revenue, or product data — so ROAS calculations and feed analysis will be incomplete.</p>
    <div style="background:var(--color-bg-grey50);border:1px solid var(--color-border);border-radius:8px;padding:12px 14px;display:flex;flex-direction:column;gap:8px;">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <span style="font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:var(--color-text-primary);">Google Ads + Search Console + GA4</span>
        <span class="badge badge-success">Connected</span>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <span style="font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:var(--color-text-primary);">Microsoft Advertising</span>
        <span class="badge badge-success">Connected</span>
      </div>
      <div style="height:1px;background:var(--color-border);"></div>
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <span style="font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:var(--color-text-primary);">Shopify</span>
        <span class="badge badge-warning">Not connected</span>
      </div>
    </div>
    <div>
      <p style="font-family:'Inter',sans-serif;font-size:12px;font-weight:600;color:var(--color-text-caption);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Limited without Shopify</p>
      <div style="display:flex;flex-direction:column;gap:5px;">
        <div style="display:flex;align-items:center;gap:8px;font-family:'Inter',sans-serif;font-size:13px;color:var(--color-text-subtitle);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Revenue attribution and ROAS calculations
        </div>
        <div style="display:flex;align-items:center;gap:8px;font-family:'Inter',sans-serif;font-size:13px;color:var(--color-text-subtitle);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-text-warning)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Feed Quality Check and Feed Data Tool
        </div>
      </div>
    </div>
    <div class="modal-footer" style="align-items:center;">
      <button id="shopify-modal-skip" class="btn-secondary" style="width:auto;padding:0 16px;">Skip for now</button>
      <button id="shopify-modal-connect" class="btn-primary-sm">Connect Shopify →</button>
    </div>
  </div>
</div>
<!-- Add Feed Database Modal -->
<div id="add-feed-modal" style="display:none;position:fixed;inset:0;background:rgba(1,3,7,0.45);z-index:9999;align-items:center;justify-content:center;opacity:0;transition:opacity 0.2s ease;">
  <div class="modal-box" style="max-width:460px;width:90%;transform:translateY(8px);transition:transform 0.2s ease;">
    <h3 class="modal-title">Add Database</h3>
    <p class="modal-desc">Add a new feed database to manage product data imports and exports.</p>
    <div style="display:flex;flex-direction:column;gap:16px;margin-top:20px;">
      <div>
        <label style="font-size:13px;font-weight:500;color:var(--color-text-primary);display:block;margin-bottom:6px;">Database name</label>
        <input type="text" placeholder="e.g. Outdoor Research – Shopping" style="width:100%;box-sizing:border-box;" />
      </div>
      <div>
        <label style="font-size:13px;font-weight:500;color:var(--color-text-primary);display:block;margin-bottom:6px;">Client</label>
        <select style="width:100%;box-sizing:border-box;">
          <option value="" disabled selected>Select client…</option>
          <option>All Volleyball</option><option>Backcountry</option><option>Craft Brew Alliance</option>
          <option>Goal Zero</option><option>Link Imaging</option><option>Monkey Sports</option>
          <option>NW Sportswear</option><option>Outdoor Research</option>
          <option>People's Choice Beef Jerky</option><option>Trijicon</option>
        </select>
      </div>
      <div>
        <label style="font-size:13px;font-weight:500;color:var(--color-text-primary);display:block;margin-bottom:6px;">Group</label>
        <select id="add-feed-group-select" style="width:100%;box-sizing:border-box;">
          <option value="" selected>None (Ungrouped)</option>
          <option value="grp-monkey-sports">Monkey Sports</option>
          <option value="grp-backcountry">Backcountry</option>
          <option value="grp-goal-zero">Goal Zero</option>
          <option value="__new__">Create new group +</option>
        </select>
      </div>
    </div>
    <div class="modal-footer" style="margin-top:24px;">
      <button id="add-feed-cancel" class="btn-secondary" style="width:auto;padding:0 20px;">Cancel</button>
      <button class="btn-primary" style="width:auto;padding:0 20px;">Add Database</button>
    </div>
  </div>
</div>
</body>
</html>
