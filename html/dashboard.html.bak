    <div id="ov-channel-wrap" style="position:relative;">
      <button class="ov-filter-btn" onclick="document.getElementById('ov-channel-panel').classList.toggle('open')" style="border-color:var(--color-blue);color:var(--color-blue);">
        <span id="ov-channel-label">SEM</span>
        <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="var(--color-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div id="ov-channel-panel" class="alerts-filter-panel">
