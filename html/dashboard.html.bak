      <button class="btn-primary-sm" style="display:flex;align-items:center;gap:6px;">
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M7 1v9M3.5 6.5L7 10l3.5-3.5M1 11.5h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Export
      </button>
    </div>
  </div>
  <p class="page-subtitle" id="ov-subtitle" style="margin-bottom:20px;">Paid search performance and optimisation insights.</p>
  <nav class="breadcrumb" style="margin-bottom:20px;">
    <span class="bc-item bc-muted">Reports</span>
    <span class="bc-muted" style="margin:0 4px;">›</span>
    <span class="bc-item" style="color:var(--color-text-primary);">Overview</span>
  </nav>

  <!-- Filter bar -->
  <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:24px;">
    <div id="ov-client-wrap" style="position:relative;">
      <button class="ov-filter-btn" onclick="document.getElementById('ov-client-panel').classList.toggle('open')">
