        <div class="alerts-filter-item" onclick="ovSetChannel('SEO')">SEO</div>
      </div>
    </div>
    <div id="ov-comp-wrap" style="position:relative;">
      <button class="ov-filter-btn" onclick="document.getElementById('ov-comp-panel').classList.toggle('open')">
